// Install the batched dense decision hook on the world's AgentLayer if the
// route config opts in. Walks all currently-living agents and toggles their
// brain's batchable mode. Safe to call multiple times across world rebuilds.
void installBatchedDenseHook(World2D& world,
                             const ProtagonistEcologyConfig& route,
                             ProtagonistBatchedDenseRunner& runner) {
    if (!route.compute.protagonist_batched_dense_enabled) return;

    auto* agent_layer = world.getLayer<AgentLayer>();
    if (agent_layer == nullptr) return;

    for (auto* agent : agent_layer->agents()) {
        if (agent == nullptr) continue;
        if (auto* brain = dynamic_cast<ProtagonistBrain*>(&agent->brain())) {
            brain->setBatchableEnabled(true);
        }
    }
    agent_layer->setBatchedDecisionHook([&runner](IWorld& w, float dt, const std::vector<Agent*>& agents) {
        runner(w, dt, agents);
    });
}

struct TrainingParams {
    std::size_t generations{0};
    std::size_t episode_ticks{0};
    SimTimeSeconds episode_duration_seconds{0.0};
    SimTimeSeconds substep_dt{0.1};
    std::size_t max_substeps_per_advance{16};
    std::size_t episodes_per_generation{3};
    std::size_t num_threads{0};  // 0 = auto-detect
    double survival_weight{1.0};
    double food_weight{10.0};
    double intrinsic_weight{5.0};
    double combat_weight{1.0};
    double cooperation_weight{6.0};
    double communication_weight{4.0};
    float combat_attack_reward{2.0f};
    float combat_kill_bonus{10.0f};
    float combat_death_penalty{5.0f};
    float worksite_proximity_reward{0.05f};
    float worksite_completion_reward{60.0f};
    // L5 #11: hard "must build to survive" gate. When true, every
    // protagonist that finishes the episode without contributing to at
    // least one completed worksite receives a -must_build_penalty
    // fitness adjustment at episode end. Off by default — set per-task
    // via [[evolution.task_templates.must_build_to_survive]] = true.
    bool must_build_to_survive{false};
    float must_build_penalty{200.0f};
    // L5 #8 Storage deposit reward. When a protagonist deposits a stick
    // or stone into a *completed* Storage building (overflow stockpile),
    // award this bonus per deposit. Without it the protagonist never
    // learns to use Storage and the building is functionally inert.
    // Scaled by cooperation_weight so it lives in the same Layer 5
    // reward family as worksite_proximity_reward and joint_hunt_reward.
    float storage_deposit_reward{0.0f};
    // Emergent shelter L1 (2026-05-22): rewards a protagonist for
    // standing inside a *completed* worksite (i.e. behind a built wall)
    // while there is at least one predator within
    // shelter_camp_predator_radius. Encodes "use the shelter" so v9 can
    // learn to pair the proactive build (worksite_proximity_reward)
    // with the late-game reuse (this) - the latter half of "fang wei du
    // jian" / proactive defence. Default 0 keeps existing scenarios
    // unchanged. Off in tasks where there is no predator pressure
    // (e.g. comm_scout_worker) - turning it on without predators is a
    // free-camp exploit (the predator gate is always false, the gate
    // never fires).
    float shelter_camp_reward{0.0f};
    float shelter_camp_predator_radius{12.0f};
    float social_proximity_reward{0.01f};
    float social_proximity_radius{6.0f};
    float signal_emit_reward{0.03f};
    float signal_emit_companion_radius{12.0f};
    float signal_co_attendance_reward{0.6f};
    float signal_co_attendance_radius{8.0f};
    SimTimeSeconds signal_co_attendance_window_seconds{40.0};
    // Listener-side reward: when an agent enters the response halo of any
    // recent emit (incl. the controlled emitter, which is what
    // signal_co_attendance_reward cannot hit), it gets this reward. Off by
    // default so existing training distributions are unaffected. The metric
    // counted by ablation eval (signal_response_events) uses the same
    // condition, so turning this on aligns the training reward with what
    // ablation eval actually measures.
    float signal_response_reward{0.0f};
    // Audit § 4.4 fix (chicken-and-egg break). Dense distance gradient for
    // a listener that is within signal_emit_companion_radius of a recent
    // peer emit but has not yet entered the response halo. Each tick the
    // listener accrues `signal_response_dense_reward * (1 - dist/radius)
    // * dt` so walking toward the emitter is immediately reinforced,
    // instead of only paying out the binary halo entry. Off by default
    // (zero) so existing training distributions are unaffected; the
    // ablation-tuned signal_response task and the camp+signal training
    // config opt in explicitly.
    float signal_response_dense_reward{0.0f};
    // A2.signal credit ledger (audit § 8 follow-up). When a controlled
    // emitter fires, listeners that enter the halo accumulate dwell time
    // until the response window closes. At settlement we publish
    // CreditAssigned{kind=2} for each listener with their dwell-share and
    // optionally pay out share * signal_response_share_reward as a
    // cooperative bonus. Default 0 so existing training distributions are
    // unaffected; turn on per-task to align dense halo dwell with explicit
    // contribution-share fitness. The CreditAssigned event is always
    // published regardless of share_reward magnitude (it carries lineage,
    // not just reward).
    float signal_response_share_reward{0.0f};
    float joint_hunt_reward{8.0f};
    float joint_hunt_radius{10.0f};
    std::size_t checkpoint_every{0};
    // 2026-05-25 disk-budget cleanup: best_genome_gen{N}.bin (1.4MB
    // each on protagonist) was written every generation in addition to
    // best_genome_latest.bin + best_genome_overall.bin, accounting for
    // ~85MB per 60-gen run. Default off; the latest/overall pair is
    // enough for resume + post-mortem inspection. Set
    // evolution.save_best_per_generation = true to opt back in (e.g.
    // for fitness-trajectory video reconstruction).
    bool save_best_per_generation{false};
    double elite_ratio{0.10};
    std::size_t tournament_size{5};
    double weight_perturb_rate{0.80};
    double weight_reset_rate{0.05};
    double weight_perturb_sigma{0.5};

    // P0 self-adaptive mutation (evolution.mutation.self_adaptive). When true,
    // each protagonist genome carries its own mutation sigma that co-evolves
    // with the weights, replacing the weight_perturb_sigma / line_sigma /
    // mutation_boost / weight_perturb_rate / weight_reset_rate knobs. Default
    // off, so the legacy fixed-sigma path is unchanged unless opted in.
    bool mutation_self_adaptive{false};
    double mutation_initial_sigma{0.10};
    double mutation_sigma_learning_rate{0.05};
    double mutation_sigma_min{0.001};
    double mutation_sigma_max{2.0};

    double prey_survival_weight{0.6};
    double prey_food_weight{4.0};
    double prey_social_weight{0.012f};
    double prey_retaliation_weight{2.5};
    double prey_death_penalty{1.5};
    double predator_survival_weight{0.4};
    double predator_kill_weight{6.0};
    double predator_attack_weight{1.0};
    double predator_social_weight{0.008f};
    double predator_death_penalty{1.5};
    float prey_social_radius{6.0f};
    float predator_social_radius{8.0f};

    double neat_add_node_rate{0.04};
    double neat_add_connection_rate{0.10};
    double neat_toggle_connection_rate{0.02};
    double neat_add_modulatory_rate{0.005};
    double neat_compatibility_threshold{3.0};

    // P1 self-adaptive species threshold (evolution.neat.target_species_count).
    // When > 0, the background-species NEAT auto-adjusts compatibility_threshold
    // each generation toward this many species (bounded by the min/max below),
    // demoting compatibility_threshold from a hand-tuned knob to a seed value.
    // Default 0 keeps the legacy hardcoded band (3..10, step 0.25, no upper clamp).
    std::size_t neat_target_species_count{0};
    double neat_compat_adjustment_rate{0.1};
    double neat_compat_threshold_min{0.5};
    double neat_compat_threshold_max{10.0};
    bool memory_cognition_enabled{true};
    bool spatial_memory_writes_enabled{true};
    bool episodic_memory_writes_enabled{true};
    bool social_memory_writes_enabled{true};
    bool goal_manager_enabled{true};

    // L2.2 v2 (SPECIES_DIFFERENTIATION_SPEC.md § 2.2). When > 0, the
    // per-tick protagonist reward includes a drive-delta penalty term
    // `drive_weight * agent.driveSetpointPenalty() * dt`. The penalty
    // is non-positive (0 when drives are at setpoint, more negative
    // otherwise), so adding it pulls fitness toward "stay homeostatic".
    // Default 0 keeps existing reward distributions untouched.
    double drive_weight{0.0};
    // L2.2 v2: thirst drive sync. When true, each tick we copy
    // (1 - hydration_ratio) from SurvivalStatusLayer into the
    // protagonist's `thirst` drive, so the drive penalty captures
    // "how dry am I". Background species don't have SurvivalStatusLayer
    // so they keep thirst = 0.
    bool drive_thirst_from_hydration{true};
    // L2.2 v2: outcome-bonus scaling. When drive_weight > 0 we typically
    // want to shrink the v9 reward components (food_weight, combat_*,
    // worksite_*, etc.) so the drive-delta term is the primary signal,
    // not yet another addition on top of the existing reward landscape.
    // Set per-task in toml; default 1.0 = keep existing components.
    double outcome_weight{1.0};
    // L2.7 v13 (HRL sub-rewards): per-goal-type completion reward
    // weight, mirrored from ProtagonistEcologyConfig.goal_completion_rewards.
    // Reward per tick = goal_completion_rewards[g] * agent.goalCompletionThisTick(g).
    // Decoupled from outcome_weight so dense HRL signals survive even
    // when outcome_weight is small.
    // L6 R3 training audit: matches ProtagonistEcologyConfig::goal_completion_rewards
    // (slot 13 = ThrowAttempt penalty, slots 14/15 reserved).
    std::array<float, 16> goal_completion_rewards{};
};

