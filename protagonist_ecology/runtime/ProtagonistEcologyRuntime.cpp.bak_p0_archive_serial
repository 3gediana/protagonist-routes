std::string makeTimestamp() {
    const auto now = std::chrono::system_clock::now();
    const std::time_t now_time = std::chrono::system_clock::to_time_t(now);
    std::tm local_tm{};
#ifdef _WIN32
    localtime_s(&local_tm, &now_time);
#else
    localtime_r(&now_time, &local_tm);
#endif
    std::ostringstream oss;
    oss << std::put_time(&local_tm, "%Y%m%d-%H%M%S");
    return oss.str();
}

std::string describeProtagonistGenomeLoadFailure(const std::filesystem::path& genome_path,
                                                 const char* prefix) {
    constexpr std::uint32_t kProtagonistGenomeFileMagic = 0x50474E4D;  // 'PGNM'

    std::ifstream stream(genome_path, std::ios::in | std::ios::binary);
    if (!stream) {
        return std::string(prefix) + genome_path.string();
    }

    std::uint32_t magic = 0;
    std::uint32_t version = 0;
    stream.read(reinterpret_cast<char*>(&magic), sizeof(magic));
    stream.read(reinterpret_cast<char*>(&version), sizeof(version));
    if (!stream) {
        return std::string(prefix) + genome_path.string() + " (truncated protagonist genome header)";
    }
    if (magic != kProtagonistGenomeFileMagic) {
        return std::string(prefix) + genome_path.string() + " (invalid protagonist genome magic)";
    }
    if (version == 1) {
        std::uint64_t genome_id = 0;
        std::uint64_t input_dim = 0;
        std::uint64_t hidden_dim = 0;
        std::uint64_t memory_cells = 0;
        std::uint64_t action_dim = 0;
        stream.read(reinterpret_cast<char*>(&genome_id), sizeof(genome_id));
        stream.read(reinterpret_cast<char*>(&input_dim), sizeof(input_dim));
        stream.read(reinterpret_cast<char*>(&hidden_dim), sizeof(hidden_dim));
        stream.read(reinterpret_cast<char*>(&memory_cells), sizeof(memory_cells));
        stream.read(reinterpret_cast<char*>(&action_dim), sizeof(action_dim));

        std::ostringstream oss;
        oss << prefix << genome_path.string()
            << " (pre-DNC protagonist genome v1 is incompatible with the current DNC route";
        if (stream) {
            oss << "; stored input_dim=" << input_dim
                << ", hidden_dim=" << hidden_dim
                << ", memory_cells=" << memory_cells
                << ", action_dim=" << action_dim;
        }
        oss << ')';
        return oss.str();
    }

    return std::string(prefix) + genome_path.string()
        + " (unsupported or corrupted protagonist genome version=" + std::to_string(version) + ')';
}

bool trainingEnabled(const config::Config& config) {
    return config.getOr<std::size_t>("evolution.generations", 0) > 0;
}

std::size_t resolveAgentDecisionThreads(std::size_t requested_threads,
                                       std::size_t available_threads,
                                       std::size_t concurrent_worlds) {
    if (requested_threads > 0) {
        return requested_threads;
    }
    const std::size_t safe_worlds = std::max<std::size_t>(1, concurrent_worlds);
    return std::max<std::size_t>(1, available_threads / safe_worlds);
}

std::size_t resolveEpisodePoolSize(std::size_t requested_threads,
                                   std::size_t available_threads,
                                   std::size_t episodes_per_generation,
                                   std::size_t agent_decision_threads) {
    const std::size_t pool_target = requested_threads == 0 ? available_threads : requested_threads;
    const std::size_t per_world_threads = std::max<std::size_t>(1, agent_decision_threads);
    const std::size_t world_budget = std::max<std::size_t>(1, available_threads / per_world_threads);
    return std::max<std::size_t>(1, std::min({episodes_per_generation, pool_target, world_budget}));
}

TrainingParams loadTrainingParams(const config::Config& config) {
    TrainingParams params;
    params.generations = config.getOr<std::size_t>("evolution.generations", 0);
    params.episode_ticks = config.getOr<std::size_t>("evolution.episode_ticks", 0);
    params.episode_duration_seconds = config.getOr<double>("simulation.time.episode_duration_seconds",
                                                           config.getOr<double>("evolution.episode_duration_seconds",
                                                                                params.episode_ticks > 0 ? static_cast<double>(params.episode_ticks) : params.episode_duration_seconds));
    params.substep_dt = config.getOr<double>("simulation.time.substep_dt", params.substep_dt);
    params.max_substeps_per_advance = config.getOr<std::size_t>("simulation.time.max_substeps_per_advance", params.max_substeps_per_advance);
    params.episodes_per_generation = config.getOr<std::size_t>("evolution.episodes_per_generation", params.episodes_per_generation);
    params.num_threads = config.getOr<std::size_t>("evolution.num_threads", params.num_threads);
    params.survival_weight = config.getOr<double>("reward.survival_weight", params.survival_weight);
    params.food_weight = config.getOr<double>("reward.food_weight", params.food_weight);
    params.intrinsic_weight = config.getOr<double>("reward.intrinsic_weight", params.intrinsic_weight);
    params.combat_weight = config.getOr<double>("reward.combat_weight", params.combat_weight);
    params.cooperation_weight = config.getOr<double>("reward.cooperation_weight", params.cooperation_weight);
    params.communication_weight = config.getOr<double>("reward.communication_weight", params.communication_weight);
    params.worksite_proximity_reward = config.getOr<float>("reward.worksite_proximity_reward", params.worksite_proximity_reward);
    params.worksite_completion_reward = config.getOr<float>("reward.worksite_completion_reward", params.worksite_completion_reward);
