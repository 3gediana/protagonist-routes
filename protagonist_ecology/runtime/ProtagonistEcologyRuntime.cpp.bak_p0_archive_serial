TrainingParams configureMemoryAblationTaskParams(const config::Config& config,
                                                 MemoryAblationTaskKind task) {
    auto params = loadTrainingParams(config);
    switch (task) {
        case MemoryAblationTaskKind::WaterReturn:
            params.survival_weight = 2.0;
            params.food_weight = 0.0;
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.cooperation_weight = 0.0;
            params.communication_weight = 0.0;
            params.worksite_proximity_reward = 0.0f;
            params.worksite_completion_reward = 0.0f;
            params.signal_emit_reward = 0.0f;
            params.signal_co_attendance_reward = 0.0f;
            params.joint_hunt_reward = 0.0f;
            break;

        case MemoryAblationTaskKind::DangerAvoidance:
            params.survival_weight = 2.5;
            params.food_weight = 0.5;
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.cooperation_weight = 0.0;
            params.communication_weight = 0.0;
            params.worksite_proximity_reward = 0.0f;
            params.worksite_completion_reward = 0.0f;
            params.signal_emit_reward = 0.0f;
            params.signal_co_attendance_reward = 0.0f;
            params.joint_hunt_reward = 0.0f;
            break;

        case MemoryAblationTaskKind::WorksiteReturn:
            params.survival_weight = 0.2;
            params.food_weight = 0.0;
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.cooperation_weight = 6.0;
            params.communication_weight = 0.0;
            params.worksite_proximity_reward = 0.08f;
            params.worksite_completion_reward = 80.0f;
            params.signal_emit_reward = 0.0f;
            params.signal_co_attendance_reward = 0.0f;
            params.joint_hunt_reward = 0.0f;
            break;

        case MemoryAblationTaskKind::SignalResponse:
            params.survival_weight = 0.2;
            params.food_weight = 4.0;
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.cooperation_weight = 0.0;
            params.communication_weight = 10.0;
            params.worksite_proximity_reward = 0.0f;
            params.worksite_completion_reward = 0.0f;
            params.signal_emit_reward = 0.2f;
            params.signal_emit_companion_radius = 30.0f;
            params.signal_co_attendance_reward = 2.5f;
            // The emitter pulses every 30s. To count as a response the
            // agent has to be inside a 12m halo within 15s of the pulse.
            // The 15s slot lets a listener that just heard the pulse walk
            // up to the emitter; the 15s silent gap that follows is what
            // forces SpatialMemory / EpisodicMemory to carry the heading
            // until the next pulse arrives.
            //
            // v6 softening: 8m -> 12m halo. With 8m the v5 retrain (which
            // already fixed the train companion_radius mismatch) still
            // produced events=0 across all variants. The dense distance
            // gradient inside 30m was being collected, but the 8m halo
            // was effectively a precision target the controller could
            // not learn in 30 generations without driving fitness through
            // food / emit-side rewards. 12m is still well inside the
            // 30m perception range so "I heard a peer therefore I am in
            // the halo" remains a non-trivial spatial task.
            params.signal_co_attendance_radius = 12.0f;
            params.signal_co_attendance_window_seconds = 15.0;
            // Listener-side rewards (audit § 4.4). Halo entry pays out
            // signal_response_reward once per (listener, emitter, emit_tick),
            // and the distance gradient inside the 30m companion radius
            // pays out signal_response_dense_reward * (1 - dist/radius)
            // every tick, both multiplied by communication_weight.
            // The dense channel exists to break the chicken-and-egg
            // observed in the prior three failed runs: the agent had no
            // perception gradient toward the emitter, so it never
            // reached the halo and never collected any reward, so it
            // never learned to head that way. With the gradient and the
            // new peer_signal_heard memory readback on perception
            // dim 18-21, the controller can now learn the chain
            // "heard signal -> turn toward source -> enter halo".
            params.signal_response_reward = 1.5f;
            params.signal_response_dense_reward = 1.0f;
            params.joint_hunt_reward = 0.0f;
            break;

        case MemoryAblationTaskKind::CommScoutWorker:
            // A3.S2 reward profile. Heavy food weight so a worker that
            // follows the signal to the emitter's food drop is paid; light
            // survival; same signal_response gradient + halo entry as
            // SignalResponse so the worker has a learnable signal path.
            params.survival_weight = 0.3;
            params.food_weight = 6.0;  // food at emitter is the win condition
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.cooperation_weight = 0.0;
            params.communication_weight = 8.0;
            params.worksite_proximity_reward = 0.0f;
            params.worksite_completion_reward = 0.0f;
            params.signal_emit_reward = 0.0f;
            params.signal_co_attendance_reward = 1.5f;
            params.signal_emit_companion_radius = 30.0f;
            params.signal_co_attendance_radius = 10.0f;
            params.signal_co_attendance_window_seconds = 10.0;
            params.signal_response_reward = 1.0f;
            params.signal_response_dense_reward = 0.8f;
            params.joint_hunt_reward = 0.0f;
            break;

        case MemoryAblationTaskKind::CommDangerWarning:
            // A3.S3 reward profile - Phase 2 redesign 2026-05-22.
            // Original Phase 1 used signal_response_dense_reward = -0.6
            // (signal -> flee), but in 200s eval episodes v8 NEAT could
            // not invert its learned positive listener gradient and the
            // primary metric (survived) stayed pinned at 8/8 because
            // randomPosition() spread predators too thin to ever kill.
            //
            // Phase 2 flips the semantics: signal = "rally to nest =
            // safe direction". Combined with route changes (12 predators
            // on a 60x60 map, emitter pinned near nest), without signal
            // the protagonist wanders and gets caught; with signal it
            // walks toward emitter (= near nest) and survives. Survived
            // becomes the real primary metric again.
            params.survival_weight = 2.0;            // bigger reward for living
            params.food_weight = 0.5;                // small, just keep them eating
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.combat_death_penalty = 20.0f;     // 12 -> 20 (loud loss signal)
            params.cooperation_weight = 0.0;
            params.communication_weight = 6.0;
            params.worksite_proximity_reward = 0.0f;
            params.worksite_completion_reward = 0.0f;
            params.signal_emit_reward = 0.0f;
            params.signal_co_attendance_reward = 1.0f;
            params.signal_emit_companion_radius = 30.0f;
            params.signal_co_attendance_radius = 12.0f;
            params.signal_co_attendance_window_seconds = 12.0;
            // Positive halo + dense reward = "follow signal toward nest".
            params.signal_response_reward = 1.5f;
            params.signal_response_dense_reward = 0.6f;
            params.joint_hunt_reward = 0.0f;
            break;

        case MemoryAblationTaskKind::CommBuildRequest:
            // A3.S4 reward profile. Combines worksite completion + signal
            // following. The protagonist must (a) listen to the signal to
            // know where worksite is, (b) gather sticks/stones, (c) deposit.
            // Largest of the three tasks because worksite logistics is its
            // own coupled mechanism.
            params.survival_weight = 0.2;
            params.food_weight = 0.0;
            params.intrinsic_weight = 0.0;
            params.combat_weight = 0.0;
            params.cooperation_weight = 6.0;
            params.communication_weight = 6.0;
            params.worksite_proximity_reward = 0.10f;
            params.worksite_completion_reward = 80.0f;
            params.signal_emit_reward = 0.0f;
            params.signal_co_attendance_reward = 1.2f;
            params.signal_emit_companion_radius = 30.0f;
            params.signal_co_attendance_radius = 10.0f;
            params.signal_co_attendance_window_seconds = 12.0;
            params.signal_response_reward = 0.8f;
            params.signal_response_dense_reward = 0.6f;
            params.joint_hunt_reward = 0.0f;
            break;
    }
    return params;
}

