struct CliArgs {
    std::string config_path = "configs/protagonist_ecology_bootstrap.toml";
    bool help = false;
    bool kin_selftest = false;
    bool social_selftest = false;
};

CliArgs parseArgs(int argc, char** argv) {
    CliArgs args;
    for (int i = 1; i < argc; ++i) {
        std::string_view a = argv[i];
        if ((a == "-h" || a == "--help")) {
            args.help = true;
        } else if (a == "--config" && i + 1 < argc) {
            args.config_path = argv[++i];
        } else if (a == "--kin-selftest") {
            args.kin_selftest = true;
        } else if (a == "--social-selftest") {
            args.social_selftest = true;
        } else {
            std::cerr << "Unknown argument: " << a << "\n";
            args.help = true;
        }
    }
    return args;
}

void printUsage(std::ostream& os) {
    os << "Usage:\n"
       << "  neural-eco-protagonist [--config <path>]\n"
       << "  neural-eco-protagonist --kin-selftest\n"
       << "  neural-eco-protagonist --social-selftest\n";
}

// Phase D Kin self-test: verifies the genetic-relatedness measure used by
// KinPerception. A near-clone of a parent genome must read as highly related;
// an independent random genome must read as ~unrelated. No world, no CUDA.
int runKinSelftest() {
    using neuro::GenomeId;
    using neuro::routes::protagonist::ProtagonistBrain;
    using neuro::routes::protagonist::ProtagonistGenome;

    std::mt19937 rng(12345u);
    constexpr std::size_t kIn = 40, kHid = 24, kCells = 8, kSlots = 16, kHeads = 2, kAct = 17;

    auto parent = ProtagonistGenome::random(GenomeId{1}, kIn, kHid, kCells, kSlots, kHeads, kAct, rng);

    // near-clone = parent + one tiny mutation step (mirrors reproduce()).
    ProtagonistGenome near_clone(*parent);
    near_clone.setId(GenomeId{2});
    {
        std::normal_distribution<float> jitter(0.0f, 0.01f);
        for (float& w : near_clone.inputHiddenWeights()) {
            w += jitter(rng);
        }
    }

    // unrelated = an independent random genome.
    auto unrelated = ProtagonistGenome::random(GenomeId{3}, kIn, kHid, kCells, kSlots, kHeads, kAct, rng);

    ProtagonistBrain brain_parent(*parent);
    ProtagonistBrain brain_clone(near_clone);
    ProtagonistBrain brain_unrelated(*unrelated);

    auto cosine = [](std::span<const float> a, std::span<const float> b) {
        float dot = 0.0f, na = 0.0f, nb = 0.0f;
        const std::size_t n = std::min(a.size(), b.size());
        for (std::size_t i = 0; i < n; ++i) {
            dot += a[i] * b[i];
            na += a[i] * a[i];
            nb += b[i] * b[i];
        }
        if (na <= 1.0e-12f || nb <= 1.0e-12f) {
            return 0.0f;
        }
        return dot / std::sqrt(na * nb);
    };

    const float self_sim = cosine(brain_parent.geneticFingerprint(), brain_parent.geneticFingerprint());
    const float kin = cosine(brain_parent.geneticFingerprint(), brain_clone.geneticFingerprint());
    const float stranger = cosine(brain_parent.geneticFingerprint(), brain_unrelated.geneticFingerprint());

    std::cout << "[kin-selftest] fingerprint dim       = " << brain_parent.geneticFingerprint().size() << "\n";
    std::cout << "[kin-selftest] self-similarity       = " << self_sim << "  (expect ~1.0)\n";
    std::cout << "[kin-selftest] near-clone relatedness = " << kin << "  (expect > 0.9)\n";
    std::cout << "[kin-selftest] unrelated relatedness  = " << stranger << "  (expect |.| < 0.3)\n";

    const bool pass = self_sim > 0.99f && kin > 0.9f && std::fabs(stranger) < 0.3f;
    std::cout << (pass ? "[kin-selftest] OVERALL PASS\n" : "[kin-selftest] OVERALL FAIL\n");
    return pass ? 0 : 1;
}

// Helper: build a real Agent backed by a ProtagonistBrain from `genome`.
std::unique_ptr<neuro::Agent> makeSocialAgent(
        neuro::AgentId id, const neuro::routes::protagonist::ProtagonistGenome& genome,
        neuro::Vec2 pos, float energy) {
    using neuro::routes::protagonist::ProtagonistBrain;
    auto brain = std::make_unique<ProtagonistBrain>(genome);
    auto agent = std::make_unique<neuro::Agent>(id, genome.id(), std::move(brain), pos, energy);
    agent->setSpeciesId(neuro::SpeciesId{1});
    agent->setPredator(false);
    return agent;
}

// Phase E/F social self-test: drives the REAL TerritorySocialPerception and
// WorldHistoryPerception against a real World2D with real layers + agents.
// Proves the channels read real sim state (not zeros): territory membership,
// dominance rank, kin-affinity vs rival-threat, structure-development and a
// rising world-age clock.
int runSocialSelftest() {
    using namespace neuro;
    using namespace neuro::routes::protagonist;

    std::mt19937 rng(2026u);
    constexpr std::size_t kIn = 40, kHid = 24, kCells = 8, kSlots = 16, kHeads = 2, kAct = 17;
    constexpr float kSenseRadius = 24.0f;
    const Vec2 kBaseCenter{50.0f, 50.0f};

    // Genomes: parent (self), near-clone (kin), unrelated (rival).
    auto parent = ProtagonistGenome::random(GenomeId{1}, kIn, kHid, kCells, kSlots, kHeads, kAct, rng);
    ProtagonistGenome kin(*parent);
    kin.setId(GenomeId{2});
    {
        std::normal_distribution<float> jitter(0.0f, 0.01f);
        for (float& w : kin.inputHiddenWeights()) w += jitter(rng);
    }
    auto unrelated = ProtagonistGenome::random(GenomeId{3}, kIn, kHid, kCells, kSlots, kHeads, kAct, rng);

    bool pass = true;

    // ---- Phase E: Territory / dominance / ally / rival --------------------
    {
        World2D world(WorldId{1}, Vec2{100.0f, 100.0f});
        world.addLayer(std::make_unique<AgentLayer>(0.0f, 0.0f, 1));
        world.addLayer(std::make_unique<BaseLayer>(kBaseCenter, 20.0f, 6.0f, 6.0f, 8.0f, -8.0f));
        auto* agents = world.getLayer<AgentLayer>();

        // self high-energy at base center; weaker kin nearby; weaker non-kin (rival) nearby.
        agents->addAgent(makeSocialAgent(AgentId{1}, *parent, kBaseCenter, 100.0f), world);
        agents->addAgent(makeSocialAgent(AgentId{2}, kin, Vec2{53.0f, 50.0f}, 40.0f), world);
        agents->addAgent(makeSocialAgent(AgentId{3}, *unrelated, Vec2{50.0f, 54.0f}, 60.0f), world);
        const Agent* self = agents->agents().front();  // first added = self

        std::array<float, TerritorySocialPerception::kDim> e{};
        TerritorySocialPerception(kSenseRadius).sense(*self, world, e);

        std::cout << "[social-selftest] E in_base        = " << e[0] << "  (expect 1)\n";
        std::cout << "[social-selftest] E dominance_rank = " << e[1] << "  (expect ~1, self strongest)\n";
        std::cout << "[social-selftest] E ally_affinity  = " << e[2] << "  (expect >0.9, nearest is kin)\n";
        std::cout << "[social-selftest] E rival_threat   = " << e[3] << "  (expect 0<t<0.6 from non-kin)\n";
        const bool e_ok = e[0] > 0.99f && e[1] > 0.99f && e[2] > 0.9f && e[3] > 0.02f && e[3] < 0.6f;
        pass = pass && e_ok;
        std::cout << (e_ok ? "[social-selftest] E PASS\n" : "[social-selftest] E FAIL\n");
    }

    // ---- Phase F.dev: development density rises with nearby structures ----
    float dev_base_only = 0.0f;
    float dev_with_fire = 0.0f;
    {
        // base-only world: self in base -> development from base footprint alone.
        World2D w0(WorldId{2}, Vec2{100.0f, 100.0f});
        w0.addLayer(std::make_unique<BaseLayer>(kBaseCenter, 20.0f, 6.0f, 6.0f, 8.0f, -8.0f));
        auto self0 = makeSocialAgent(AgentId{9}, *parent, kBaseCenter, 100.0f);
        std::array<float, WorldHistoryPerception::kDim> f0{};
        WorldHistoryPerception(kSenseRadius).sense(*self0, w0, f0);
        dev_base_only = f0[0];

        // base + campfires near self -> strictly more development.
        World2D w1(WorldId{3}, Vec2{100.0f, 100.0f});
        w1.addLayer(std::make_unique<AgentLayer>(0.0f, 0.0f, 1));
        w1.addLayer(std::make_unique<BaseLayer>(kBaseCenter, 20.0f, 6.0f, 6.0f, 8.0f, -8.0f));
        w1.addLayer(std::make_unique<CampfireLayer>(2, 8.0f, 6.0f, 4.0f, 8.0f, -8.0f, 7u));
        auto self1 = makeSocialAgent(AgentId{10}, *parent, kBaseCenter, 100.0f);
        std::array<float, WorldHistoryPerception::kDim> f1{};
        WorldHistoryPerception(kSenseRadius).sense(*self1, w1, f1);
        dev_with_fire = f1[0];

        std::cout << "[social-selftest] F dev base-only  = " << dev_base_only << "  (expect >0)\n";
        std::cout << "[social-selftest] F dev base+fires = " << dev_with_fire << "  (expect > base-only)\n";
    }
    const bool dev_ok = dev_base_only > 0.0f && dev_with_fire > dev_base_only && dev_with_fire <= 1.0f;
    pass = pass && dev_ok;
    std::cout << (dev_ok ? "[social-selftest] F.dev PASS\n" : "[social-selftest] F.dev FAIL\n");

    // ---- Phase F.age: world-age signal rises monotonically with the clock --
    {
        World2D wa(WorldId{4}, Vec2{100.0f, 100.0f});
        wa.addLayer(std::make_unique<BaseLayer>(kBaseCenter, 20.0f, 6.0f, 6.0f, 8.0f, -8.0f));
        auto selfa = makeSocialAgent(AgentId{11}, *parent, kBaseCenter, 100.0f);
        WorldHistoryPerception wh(kSenseRadius);

        std::array<float, WorldHistoryPerception::kDim> fa0{};
        wh.sense(*selfa, wa, fa0);                     // t = 0
        for (int i = 0; i < 6; ++i) wa.tick(100.0f);   // advance clock ~600s
        std::array<float, WorldHistoryPerception::kDim> fa1{};
        wh.sense(*selfa, wa, fa1);                     // t > 0

        std::cout << "[social-selftest] F age t=0        = " << fa0[1] << "  (expect ~0)\n";
        std::cout << "[social-selftest] F age t>0        = " << fa1[1] << "  (expect >0, <1)\n";
        const bool age_ok = fa0[1] < 0.05f && fa1[1] > fa0[1] && fa1[1] < 1.0f;
        pass = pass && age_ok;
        std::cout << (age_ok ? "[social-selftest] F.age PASS\n" : "[social-selftest] F.age FAIL\n");
    }

    std::cout << (pass ? "[social-selftest] OVERALL PASS\n" : "[social-selftest] OVERALL FAIL\n");
    return pass ? 0 : 1;
}

}  // namespace

int main(int argc, char** argv) {
    const CliArgs args = parseArgs(argc, argv);
    if (args.help) {
        printUsage(std::cout);
        return 0;
    }
    if (args.kin_selftest) {
        return runKinSelftest();
    }
    if (args.social_selftest) {
        return runSocialSelftest();
    }

    neuro::config::Config config;
    try {
        config = neuro::config::Config::loadFromFile(args.config_path);
    } catch (const std::exception& e) {
        std::cerr << "Config error: " << e.what() << "\n";
        return 2;
    }

    neuro::log::Options log_opts;
    log_opts.level = config.getOr<std::string>("runtime.log_level", "info");
    log_opts.console = true;
    neuro::log::initialize(log_opts);

    int rc = 0;
    try {
        neuro::routes::protagonist::ProtagonistEcologyRuntime runtime(std::move(config));
        runtime.initialize();
        rc = runtime.run();
    } catch (const std::exception& e) {
        LOG_CRITICAL("Unhandled exception: {}", e.what());
        rc = 1;
    }

    neuro::log::shutdown();
    return rc;
}
