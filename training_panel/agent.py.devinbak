            ["tune_id", "reason"]),
        _fn("curriculum_advance",
            "【沿预设课程阶梯自主推进一档】仅当存在人工预先评定好的课程阶梯(curriculum_ladder.json)时可自主把课程推进到下一档;"
            "这给你『渐进难度』这个必需杠杆,又不让你凭空造任务。若没有预设阶梯,则退回到 pe_curriculum_edit(高风险→人批)。先 kb_query。",
            {"config": {"type": "string", "description": "当前 PE TOML"},
             "reason": {"type": "string"}, "purpose": {"type": "string"}},
            ["config", "reason"]),
        # ---- roadmap: 常驻长期规划(像 Codex /goal,持久 to-do) ---------- #
        _fn("plan_roadmap",
            "【常驻规划·开工先做】把这次的【整条长期路线】一次规划成一串有序目标卡(像我给你列 to-do)。"
            "模型A语义:每张卡=一条可量化验收约束(metric/op/target 或 rel 相对基线);"
            "所有卡【同时达标并稳住】才算整条完成;order 只是『先主攻谁』不决定完成。"
            "达标判定由代码读真 eval 算,你不能自己宣布完成。开工/方向变化时先调它把路线摆出来,再动手执行。"
            "metric 可用: me_cov/qd/avg/best/extinct(PE)、score/reward/unlocks(DP)、"
            "understanding_dp(DP世界理解分)、understanding_mem(PE记忆理解分)。",
            {"objective": {"type": "string", "description": "这条路线的顶层长期目标(一句话北极星)"},
             "goals": {"type": "array", "description": "有序目标卡列表",
                       "items": {"type": "object", "properties": {
                           "title": {"type": "string"},
                           "detail": {"type": "string"},
                           "project": {"type": "string", "enum": ["pe", "dp", "any"]},
                           "acceptance": {"type": "array", "description":
                                          "验收子句(全部满足=本卡达标)",
                                          "items": {"type": "object", "properties": {
                                              "metric": {"type": "string"},
                                              "op": {"type": "string", "enum": [">=", "<=", ">", "<"]},
                                              "target": {"type": "number", "description": "绝对阈值(与 rel 二选一)"},
                                              "rel": {"type": "number", "description": "相对基线提升比例,如 0.15=较创建时基线+15%"},
                                              "file": {"type": "string", "description": "可选:指定 run 文件/目录;留空=自动取最新"}}}}}}},
             "hold_window": {"type": "integer", "description": "全达标需连续稳住几次(默认2)"},
             "stall_after": {"type": "integer", "description": "某卡零改进多少次判受阻(默认6)"},
             "stall_policy": {"type": "string", "enum": ["skip", "hold"],
                              "description": "撞天花板后:skip=跳下一张继续(默认),hold=停等人"},
             "reason": {"type": "string"}},
            ["objective", "goals"]),
        _fn("roadmap_status",
            "【只读·随时可调,建议每轮开工先看】读当前 roadmap:顶层目标、每张卡的状态(进行中/达标/受阻)、"
            "实时进度、当前主攻哪张、各验收子句的实测值 vs 目标。代码现算,反映真实 eval。"
            "没有活跃 roadmap 时会提示你先 plan_roadmap。",
            {}),
        _fn("roadmap_edit",
            "增量改 roadmap(不必整条重列):add_goal 加卡 / update_goal 改某卡 / remove_goal 删卡 / "
            "reorder 重排主攻顺序 / reopen 把受阻卡重新打开 / set_objective 改顶层目标 / "
            "pause 暂停 / resume 恢复 / set_policy 改 stall_policy。注意:你不能把卡直接设成『达标』——"
            "达标只能由代码从实测指标判定。",
            {"op": {"type": "string", "enum": ["add_goal", "update_goal",
                    "remove_goal", "reorder", "reopen", "set_objective",
                    "pause", "resume", "set_policy"]},
             "goal": {"type": "object", "description": "add_goal/update_goal 用;同 plan_roadmap 的卡结构(update 需带 id)"},
             "id": {"type": "string", "description": "remove_goal/reopen 用:卡 id"},
             "order": {"type": "array", "items": {"type": "string"},
                       "description": "reorder 用:按新顺序排列的卡 id 列表"},
             "objective": {"type": "string", "description": "set_objective 用"},
             "stall_policy": {"type": "string", "enum": ["skip", "hold"]},
             "reason": {"type": "string"}},
            ["op"]),
    ]


# --------------------------------------------------------------------------- #
# Tool network: project partition + hybrid resident-core / long-tail packs.
#   project: "any"    -> resident, project-agnostic (perception/memory/meta)
#            "shared" -> available once a focus is set, scoped to that focus
#            "dp"/"pe"-> only visible under that focus
#   pack in LONGTAIL_PACKS -> hidden until find_tools activates it (focus-scoped)
# --------------------------------------------------------------------------- #
LONGTAIL_PACKS = {"dp_pipeline", "pe_reward", "pe_evolution", "pe_curriculum"}

TOOL_META: dict[str, dict[str, Any]] = {
    # resident core (project-agnostic): perception + memory + meta + switches
    "get_status": {"project": "any"},
    "focus_project": {"project": "any"},
    "find_tools": {"project": "any"},
    "kb_query": {"project": "any"}, "kb_write": {"project": "any"},
    "record_gen": {"project": "any"}, "query_gens": {"project": "any"},
    "use_strategy": {"project": "any"}, "list_strategies": {"project": "any"},
    "sleep": {"project": "any"}, "log_note": {"project": "any"},
    "pin_spec": {"project": "any"}, "recall_timeline": {"project": "any"},
    "list_docs": {"project": "any"}, "read_doc": {"project": "any"},
    "deep_think": {"project": "any"},
    # shared reads/controls — scoped to the current focus (project arg forced)
    "analyze_metrics": {"project": "shared"}, "compare_runs": {"project": "shared"},
    "analyze_memory_ablation": {"project": "shared"},
    "analyze_dp_counterfactual": {"project": "shared"},
    "read_log_tail": {"project": "shared"}, "cleanup_disk": {"project": "shared"},
    "stop_training": {"project": "shared"}, "list_checkpoints": {"project": "shared"},
    # autonomous campaign controller — campaign_status is resident/read-only;
    # start/advance act on the current focus project (shared, serialized).
    "campaign_status": {"project": "any"},
    "start_campaign": {"project": "shared"}, "advance_campaign": {"project": "shared"},
    # roadmap: persistent long-horizon plan — all resident/project-agnostic.
    "plan_roadmap": {"project": "any"}, "roadmap_status": {"project": "any"},
    "roadmap_edit": {"project": "any"},
    # DP focus — primary (auto-active) + long-tail pipeline (find_tools)
    "start_dp_training": {"project": "dp"},
    "dp_counterfactual_probe": {"project": "dp"},
    "delete_checkpoint": {"project": "dp"},
    "dp_record_demos": {"project": "dp", "pack": "dp_pipeline"},
    "dp_train_bc": {"project": "dp", "pack": "dp_pipeline"},
    "dp_dagger": {"project": "dp", "pack": "dp_pipeline"},
    "dp_finetune": {"project": "dp", "pack": "dp_pipeline"},
    # PE focus — primary (auto-active) + long-tail tuning packs (find_tools)
    "start_pe_training": {"project": "pe"},
    "list_pe_configs": {"project": "pe"},
    "inspect_config": {"project": "pe"},
    "make_config_variant": {"project": "pe"},
    "make_memory_ablation_config": {"project": "pe"},
    "pe_reward_tune": {"project": "pe", "pack": "pe_reward"},
    "pe_archive_geometry": {"project": "pe", "pack": "pe_evolution"},
    "pe_evolution_tune": {"project": "pe", "pack": "pe_evolution"},
    "pe_curriculum_edit": {"project": "pe", "pack": "pe_curriculum"},
    # PE autonomy: bounded auto-tune loop + vetted-ladder curriculum advance
    "start_tune": {"project": "pe", "pack": "pe_reward"},
    "resolve_tune": {"project": "pe", "pack": "pe_reward"},
    "curriculum_advance": {"project": "pe", "pack": "pe_curriculum"},
}

# keyword -> pack, for find_tools discovery (focus-scoped at call time).
_PACK_KEYWORDS: dict[str, list[str]] = {
    "dp_pipeline": ["bc", "克隆", "clone", "老师", "teacher", "oracle", "demos",
                    "数据集", "dataset", "record", "录", "dagger", "纠偏",
                    "finetune", "微调", "ppo", "shaping", "塑形", "pipeline", "流水线"],
    "pe_reward": ["reward", "奖励", "惩罚", "penalty", "权重", "weight", "combat",
                  "tune", "调参", "闭环", "auto", "自动", "sweep", "扫"],
    "pe_evolution": ["archive", "档案", "几何", "geometry", "cvt", "bin", "bins",
                     "centroid", "质心", "evolution", "进化", "neat", "mutation",
                     "sigma", "selection", "精英", "elite"],
    "pe_curriculum": ["curriculum", "课程", "task", "任务", "template",
                      "task_templates", "难度", "difficulty", "阶梯", "ladder",
                      "推进", "advance", "进阶"],
}


def _tool_visible(name: str, focus: Optional[str], active_packs: set[str]) -> bool:
    """Whether a tool should appear in the schema given the current focus +
    activated long-tail packs. Pure -> unit-testable."""
    meta = TOOL_META.get(name)
    if meta is None:
        return True                      # unknown -> default visible (safety)
    proj = meta["project"]
    if proj == "any":
        return True
    if focus is None:
        return False                     # must focus_project first
    if proj == "shared":
        return True
    if proj != focus:
        return False
    pack = meta.get("pack")
    if pack in LONGTAIL_PACKS:
        return pack in active_packs      # long-tail: only after find_tools
    return True                          # focus's primary tool


def _packs_for_focus(focus: Optional[str]) -> set[str]:
    return {p for p in LONGTAIL_PACKS
            if (p.startswith("dp_") and focus == "dp")
            or (p.startswith("pe_") and focus == "pe")}


def _find_tools(keyword: str, pack: str, focus: Optional[str]) -> dict[str, Any]:
    """Search the focus project's long-tail packs by keyword/pack name and
    ACTIVATE the matches (their real schemas appear next turn)."""
    if focus is None:
        return {"ok": False, "error": "请先 focus_project(dp|pe) 再检索工具网络。"}
    allowed = _packs_for_focus(focus)
    kw = (keyword or "").strip().lower()
    matched: set[str] = set()
    if pack:
        p = pack.strip().lower()
        if p in allowed:
            matched.add(p)
    for pk in allowed:
        if pk in matched:
            continue
        if kw and any(term in kw or kw in term for term in _PACK_KEYWORDS.get(pk, [])):
            matched.add(pk)
    if not matched and not pack and kw:
        # also match against tool names/descriptions directly
        for nm, meta in TOOL_META.items():
            pk = meta.get("pack")
            if pk in allowed and kw in nm.lower():
                matched.add(pk)
    if not matched:
        return {"ok": True, "activated": [], "tools": [],
                "note": f"焦点[{focus}]下未匹配到长尾工具(可用包: {sorted(allowed)})。"
                        "动作类工具大多已常驻,直接调用即可。"}
    STATE.active_packs |= matched
    defs = {d["function"]["name"]: d["function"]["description"]
            for d in _all_tool_defs()}
    tools = [{"name": nm, "pack": meta.get("pack"),
              "desc": defs.get(nm, "")[:160]}
             for nm, meta in TOOL_META.items()
             if meta.get("pack") in matched]
    _timeline("find_tools", keyword=keyword, pack=pack, focus=focus,
              activated=sorted(matched), tools=[t["name"] for t in tools])
    return {"ok": True, "activated": sorted(matched), "tools": tools,
            "note": "已激活,下一轮可直接像普通工具一样带参数调用这些工具。"}


def _tool_schemas() -> list[dict[str, Any]]:
    focus = STATE.focus_project
    packs = STATE.active_packs
    return [d for d in _all_tool_defs()
            if _tool_visible(d["function"]["name"], focus, packs)]


def _tool_network_view(focus: Optional[str], packs: set[str]) -> dict[str, Any]:
    """A UI-facing description of the partitioned tool network: every tool with
    its project/pack and whether it is currently visible/activated."""
    cat = {d["function"]["name"]: (d["function"]["description"] or "")[:90]
           for d in _all_tool_defs()}
    tools = []
    for nm, meta in TOOL_META.items():
        pk = meta.get("pack")
        longtail = pk in LONGTAIL_PACKS
        tools.append({
            "name": nm, "project": meta["project"], "pack": pk,
            "longtail": longtail,
            "active": (pk in packs) if longtail else None,
            "visible": _tool_visible(nm, focus, packs),
            "desc": cat.get(nm, ""),
        })
    return {"focus": focus, "active_packs": sorted(packs),
            "packs": sorted(LONGTAIL_PACKS), "tools": tools}


READ_TOOLS = {"get_status", "list_pe_configs", "list_checkpoints", "read_log_tail",
              "analyze_metrics", "compare_runs", "analyze_memory_ablation",
              "analyze_dp_counterfactual", "inspect_config",
              "sleep", "log_note", "cleanup_disk", "pin_spec",
              "recall_timeline", "list_docs", "read_doc",
              "kb_write", "kb_query", "record_gen", "query_gens",
              "use_strategy", "list_strategies", "deep_think",
              "focus_project", "find_tools"}

# Pure, side-effect-free reads that are safe to run concurrently (claude-code
# `isConcurrencySafe`): the agent loop batches a run of consecutive such calls
# and executes them in parallel. Everything else (writes, control flow such as
# sleep/deep_think, KB/ledger writes, strategy switches) runs serially in order.
CONCURRENCY_SAFE_TOOLS = {"get_status", "list_pe_configs", "list_checkpoints",
                          "read_log_tail", "analyze_metrics", "compare_runs",
                          "analyze_memory_ablation", "analyze_dp_counterfactual",
                          "inspect_config", "recall_timeline", "list_docs",
                          "read_doc", "kb_query", "query_gens", "list_strategies",
                          "campaign_status"}


# --------------------------------------------------------------------------- #
# Guards.
# --------------------------------------------------------------------------- #
def _guard_launch(cfg: dict[str, Any]) -> Optional[str]:
    """Return a refusal reason string if a new training MUST NOT start, else None."""
    import server
    try:
        procs = server.processes()
        if procs.get("total", 0) >= cfg.get("max_procs", 10):
            return (f"拒绝启动:已有 {procs['total']} 个训练进程,达到上限 "
                    f"{cfg['max_procs']}。请先停掉一些或等其结束。")
    except Exception:  # noqa: BLE001
        pass
    try:
        st = server.system_status()
        disk = st.get("disk") or {}
        free = disk.get("free_gb")
        if free is not None and free < cfg.get("disk_low_gb", 25.0):
            return (f"拒绝启动:磁盘只剩 {free}G,低于阈值 {cfg['disk_low_gb']}G。"
                    f"请先 cleanup_disk 释放空间。")
        # Single 8G card: refuse a new launch when no GPU has enough free VRAM,
        # so we fail loud here instead of OOM-crashing mid-train. Take the GPU
        # with the MOST free memory (the freest candidate the run could land on).
        gpu = st.get("gpu")
        rows = gpu if isinstance(gpu, list) else ([gpu] if gpu else [])
        min_free = cfg.get("gpu_min_free_mb", 1500.0)
        frees = [r["mem_total_mb"] - r["mem_used_mb"] for r in rows
                 if isinstance(r, dict) and r.get("mem_total_mb") is not None
                 and r.get("mem_used_mb") is not None]
        if frees and max(frees) < min_free:
            return (f"拒绝启动:GPU 可用显存只剩 {max(frees):.0f}MB,低于安全余量 "
                    f"{min_free:.0f}MB。等显存释放或先 stop_training 腾显存,避免 OOM 崩溃。")
    except Exception:  # noqa: BLE001
        pass
    return None


# --------------------------------------------------------------------------- #
# Tier-C risk classification (in code, not left to the LLM). High-risk ops are
# queued for human approval EVEN IN AUTO mode. Pure functions -> unit-testable.
# --------------------------------------------------------------------------- #
def _num(v: Any) -> Optional[float]:
    try:
        return float(v)
    except (TypeError, ValueError):
        return None


def _reward_edit_is_structural(edits: dict[str, Any], pct_limit: float) -> Optional[str]:
    """A PE reward edit is STRUCTURAL (high-risk) if any knob flips sign, more
    than doubles/halves (|Δ|/old > pct_limit), or zeroes/un-zeroes a term.
    Returns a human reason string if structural, else None.
    NOTE: we can only check magnitude against the *proposed* value here; the
    server's pe_tune dry_run gives the authoritative old->new delta, which the
    gate below uses. This is the value-only heuristic for when old is unknown."""
    for knob, new in (edits or {}).items():
        n = _num(new)
        if n is None:
            return f"{knob} 改成非数值(结构性改动)"
    return None


def _delta_is_structural(delta: dict[str, Any], pct_limit: float) -> bool:
    """Given a server _knob_delta() dict, decide if it's structural."""
    if not delta.get("numeric"):
        return True                       # non-numeric / added / removed key
    if delta.get("sign_flip"):
        return True
    pct = delta.get("abs_pct_change")
    if pct is None:                       # old==0 and new!=0 -> infinite change
        return True
    return pct > pct_limit


def _hard_cap_violation(name: str, args: dict[str, Any],
                        cfg: dict[str, Any]) -> Optional[str]:
    """HARD safety rail, enforced in EVERY mode (incl. full-auto). Returns a
    refusal reason for ops that would be IRREVERSIBLE or RUNAWAY-BURN beyond a
    ceiling, else None. Unlike the Tier-C approval gate (which queues for a
    human), a hard-cap hit REFUSES outright: the agent must scale the change
    down and retry, so the user is never asked to click. Concurrency/disk/GPU
    rails live in _guard_launch; protected-checkpoint deletion is hard-skipped
    server-side. This covers the remaining 'don't wreck a good model / don't
    burn GPU forever' cases."""
    tc = cfg.get("tier_c", {})
    if name == "start_dp_training":
        cap = int(tc.get("dp_steps_hard_cap", 12_000_000))
        steps = int(args.get("steps", 0) or 0)
        if steps > cap:
            return (f"DP steps={steps} 超过硬上限 {cap}(防一条指令无限烧 GPU)。"
                    f"拆成多段或调小 steps 再跑。")
    elif name == "start_pe_training":
        cap = int(tc.get("pe_gens_hard_cap", 120))
        gens = args.get("generations")
        if gens is not None and int(gens) > cap:
            return (f"PE generations={gens} 超过硬上限 {cap}(防失控长跑)。"
                    f"调小 generations 再跑。")
    elif name == "pe_reward_tune":
        hard = float(tc.get("reward_pct_hard_cap", 3.0))
        try:
            import server
            res = server.pe_tune(server.PETuneReq(
                config=args.get("config", ""), edits=args.get("edits") or {},
                label=args.get("label") or "hardcap", dry_run=True))
            for a in res.get("applied") or []:
                d = a.get("delta") or {}
                pct = d.get("abs_pct_change")
                if d.get("numeric") and pct is not None and pct > hard:
                    return (f"奖励 {a.get('knob')} 改动幅度 {pct*100:.0f}% 超过硬上限 "
                            f"{hard*100:.0f}%(防一次把目标改崩,不可逆地毁掉好模型)。"
                            f"分多次小步改。")
        except Exception:  # noqa: BLE001
            pass    # dry-run unavailable -> defer to server-side validation
    return None


def _is_new_bloodline(name: str, args: dict[str, Any], cfg: dict[str, Any]) -> Optional[str]:
    """A training launch that starts a FRESH lineage (no base ckpt/resume) and
    runs past smoke length = high-risk new bloodline -> approval even in auto."""
    tc = cfg.get("tier_c", {})
    if name == "start_dp_training":
        if args.get("checkpoint"):
            return None
        steps = int(args.get("steps", 8_000_000) or 0)
        if steps > int(tc.get("dp_smoke_steps", 200000)):
            return f"无基线 checkpoint 且 steps={steps}(>smoke)= 起新 DP 血脉"
    elif name == "start_pe_training":
        if args.get("resume_checkpoint"):
            return None
        gens = args.get("generations")
        gens = int(gens) if gens is not None else 10_000   # unset = long run
        if gens > int(tc.get("pe_smoke_generations", 4)):
            return f"无 resume 且 generations={gens}(>smoke)= 起新 PE 血脉"
    return None


def _needs_approval(name: str, args: dict[str, Any],
                    cfg: dict[str, Any]) -> tuple[bool, str]:
    """Tier-C gate: return (needs_approval, reason) for HIGH-risk ops that must
    queue for a human EVEN IN AUTO mode. Low-risk ops return (False, "").

    Full-autonomy: when mode=="auto" and tier_c.auto_approve is on, NOTHING here
    queues — the user opted to run hands-free, and safety is delegated to the
    HARD rails (_hard_cap_violation + _guard_launch), which refuse irreversible/
    runaway ops outright instead of asking the user to click."""
    tc = cfg.get("tier_c", {})
    if cfg.get("mode") == "auto" and bool(tc.get("auto_approve", True)):
        return False, ""
    pct_limit = float(tc.get("reward_pct_limit", 0.25))
    if name == "pe_curriculum_edit":
        return True, "改课程(task_templates)是 PE 最高杠杆,高风险——只提议、等人工批准。"
    if name == "pe_reward_tune":
        # authoritative: ask server pe_tune dry_run for old->new deltas
        try:
            import server
            res = server.pe_tune(server.PETuneReq(
                config=args.get("config", ""), edits=args.get("edits") or {},
                label=args.get("label") or "reward", dry_run=True))
            applied = res.get("applied") or []
            risky = [a.get("knob") for a in applied
                     if _delta_is_structural(a.get("delta") or {}, pct_limit)]
            if risky:
                return True, ("奖励【结构性】改动(变号/幅度>%.0f%%/增删项): %s —— 需人工批准。"
                              % (pct_limit * 100, ", ".join(risky)))
        except Exception:  # noqa: BLE001
            # if we cannot verify, be conservative on non-numeric edits only
            s = _reward_edit_is_structural(args.get("edits") or {}, pct_limit)
            if s:
                return True, s + " —— 需人工批准。"
        return False, ""
    if name in ("start_dp_training", "start_pe_training"):
        nb = _is_new_bloodline(name, args, cfg)
        if nb:
            return True, nb + " —— 需人工批准(即使在自主模式)。"
    return False, ""


# --------------------------------------------------------------------------- #
# Autonomous training campaigns (blueprint-level autonomy).
#
# A campaign lets the agent drive a FULL training lineage on its own without a
# human approving every escalation, while a human-equivalent *direct* full-scale
# launch still needs approval. Safety moves from "a human approves each
# high-leverage launch" to "CODE enforces a staged validation ladder + health
# gates":   smoke -> (health pass) -> short -> (health pass) -> long.
# Every promotion verdict is computed IN CODE from the stage's own metrics; the
# LLM cannot fabricate a "promote" for a failing stage. Failing health reverts
# to the last good stage and HOLDS (no infinite escalation). This is the
# mechanism that closes the "agent alone reaches a ~good model" gap, without
# opening the Goodhart/instability footgun (objective/curriculum/mechanism
# redesign stay human-gated).
# --------------------------------------------------------------------------- #
CAMPAIGN_PATH = AGENT_DIR / "agent_campaigns.json"
CURRICULUM_LADDER_PATH = AGENT_DIR / "curriculum_ladder.json"

CAMPAIGN_STAGES = ["smoke", "short", "long"]
_DP_LADDER_STEPS = {"smoke": 200_000, "short": 1_000_000, "long": 8_000_000}
_PE_LADDER_GENS = {"smoke": 4, "short": 15, "long": 60}


def _campaign_stages(project: str, tc: dict[str, Any]) -> dict[str, int]:
    """Per-stage scale (DP steps / PE generations), overridable from tier_c."""
    if project == "dp":
        d = dict(_DP_LADDER_STEPS)
        d["smoke"] = int(tc.get("dp_smoke_steps", d["smoke"]))
        override = tc.get("dp_ladder_steps") or {}
    else:
        d = dict(_PE_LADDER_GENS)
        d["smoke"] = int(tc.get("pe_smoke_generations", d["smoke"]))
        override = tc.get("pe_ladder_generations") or {}
    for k, v in override.items():
        if k in d and _num(v) is not None:
            d[k] = int(v)
    return d


def _campaign_verdict(project: str, am: dict[str, Any], *,
                      at_final: bool) -> tuple[str, str]:
    """Decide the next move from analyze_metrics output. PURE -> unit-testable.
    Returns one of: promote | revert | extend | done | stop, plus a reason.

    PREFERRED path (when the behavioural panorama resolved): a MULTI-AXIS verdict
    over a PROGRESS axis (方向: main-line depth / fitness) and a BREADTH axis
    (不退化: repertoire-per-life / MAP-Elites coverage). The anti-Goodhart rule —
    a collapsing breadth axis vetoes promotion even when progress rises — is what
    keeps '永续自迭代' from drifting into score-gaming single-strategy collapse.

    FALLBACK (panorama unavailable): the legacy coarse-scalar logic so older runs
    / log-only PE still get a conservative verdict. Extinction or any declining
    metric -> revert; improvement -> promote; plateau -> done at final else
    promote; too few points -> extend; unreadable -> stop."""
    if not am or not am.get("ok"):
        return "stop", "无法读取指标(metrics 不可解析)——不盲目晋级,停下待人工。"
    # preferred: multi-axis (progress vs breadth) with anti-Goodhart veto
    axt = am.get("axes_trend")
    if axt and axt.get("progress") and axt.get("breadth"):
        extinct = project == "pe" and (am.get("extinct_hits") or 0) > 0
        return spectrum.multi_axis_verdict(
            axt["progress"], axt["breadth"], at_final=at_final, extinct=extinct)
    if project == "pe":
        if (am.get("extinct_hits") or 0) > 0:
            return "revert", "检测到灭绝(extinct)——回退到上一阶段并保持,别继续加压。"
        keys = ["avg", "qd", "me_cov"]
    else:
        keys = ["score", "reward", "unlocks"]
    verds = [(am.get(k) or {}).get("verdict") for k in keys]
    verds = [v for v in verds if v]
    if not verds or all(v == "too_short" for v in verds):
        return "extend", "样本太少,延长观察一档再判定。"
    if any(v == "declining" for v in verds):
        return "revert", ("指标下行(%s 中出现 declining)——回退保持,先查既往坑。"
                          % "/".join(keys))
    if any(v == "improving" for v in verds):
        if at_final:
            return "done", "最终阶段仍在上行且无更大规模可升——产出当前最优,收尾。"
        return "promote", "指标上行且无下行——晋级到更大规模/更长训练。"
    # all plateau (no improving, no declining)
    if at_final:
        return "done", "最终阶段进入平台——视为收敛,产出当前最优,结束。"
    return "promote", "当前规模已学满(平台)——晋级到更大规模继续提升。"


def _load_campaigns() -> list[dict[str, Any]]:
    if CAMPAIGN_PATH.exists():
        try:
            data = json.loads(CAMPAIGN_PATH.read_text(encoding="utf-8"))
            return data if isinstance(data, list) else []
        except Exception:  # noqa: BLE001
            return []
    return []


def _save_campaigns(camps: list[dict[str, Any]]) -> None:
    CAMPAIGN_PATH.write_text(json.dumps(camps, ensure_ascii=False, indent=2),
                             encoding="utf-8")


def _find_campaign(camps: list[dict[str, Any]], cid: str) -> Optional[dict[str, Any]]:
    for c in camps:
        if c.get("id") == cid:
            return c
    return None


# --------------------------------------------------------------------------- #
# Roadmap — the agent's persistent, user-visible plan (Codex /goal-style).
#
# Model A "联合达标 + 主攻顺序" (user's choice):
#   * Each goal card is a CONSTRAINT: metric `op` target (absolute `target`, or
#     `rel` = fraction over a baseline captured when the goal was created). A card
#     is "met" when ALL its clauses hold RIGHT NOW.
#   * The whole roadmap is COMPLETE only when EVERY (non-blocked) card is met
#     SIMULTANEOUSLY and stays met across `hold_window` consecutive checks
#     (anti lucky-episode).
#   * `order` is ATTACK PRIORITY only — which card to push next — NOT a completion
#     gate. So a later push that breaks an earlier card flips it back to 不达标
#     (the honest 打地鼠 / regression alarm) and the roadmap is不算完成.
#   * Stall guard: a card whose progress shows no improvement for `stall_after`
#     checks is marked "blocked"(撞机制天花板)with a diagnosis; default
#     stall_policy="skip" moves attention to the next pushable card so the agent
#     stays hands-free instead of grinding a wall forever.
#   * VERDICTS ARE COMPUTED IN CODE from real eval metrics — the LLM can author /
#     edit goals but can NEVER declare a card "met"; only _roadmap_tick can, and
#     only from measured numbers. That is what makes "它说完成了" trustworthy.
# --------------------------------------------------------------------------- #
ROADMAP_PATH = AGENT_DIR / "agent_roadmap.json"

# metric -> the analyzer/source that produces its live value.
#   "pe"     -> _analyze_metrics("pe")  : me_cov / qd / avg / best / extinct
#   "dp"     -> _analyze_metrics("dp")  : score / reward / unlocks
#   "dp_cf"  -> _analyze_dp_counterfactual : understanding_dp (世界理解分)
#   "mem"    -> _analyze_memory_ablation   : understanding_mem (记忆理解分)
_ROADMAP_METRICS = {
    "me_cov": "pe", "qd": "pe", "avg": "pe", "best": "pe", "extinct": "pe",
    "score": "dp", "reward": "dp", "unlocks": "dp",
    "understanding_dp": "dp_cf", "understanding_mem": "mem",
}
_ROADMAP_OPS = {">=", "<=", ">", "<"}

# Tolerance: how close a metric must be to target to count as "near met".
# Default 5%, minimum absolute delta 0.01. Avoids rigid pass/fail at boundary.
_NEAR_MET_TOLERANCE = 0.05  # 5% relative tolerance
_NEAR_MET_MIN_ABS = 0.01   # minimum absolute tolerance


def _roadmap_default() -> dict[str, Any]:
    return {"version": 1, "active": False, "objective": "", "goals": [],
            "hold_window": 2, "stall_after": 6, "stall_policy": "skip",
            "all_met_streak": 0, "completed_at": None, "updated_at": time.time()}


def _load_roadmap() -> dict[str, Any]:
    if ROADMAP_PATH.exists():
        try:
            d = json.loads(ROADMAP_PATH.read_text(encoding="utf-8"))
            if isinstance(d, dict):
                base = _roadmap_default()
                base.update(d)
                return base
        except Exception:  # noqa: BLE001
            pass
    return _roadmap_default()


def _save_roadmap(rm: dict[str, Any]) -> None:
    rm["updated_at"] = time.time()
    ROADMAP_PATH.write_text(json.dumps(rm, ensure_ascii=False, indent=2),
                            encoding="utf-8")


def _roadmap_latest_file(source: str) -> str:
    """Newest run artifact a metric source reads, so a clause need not name a
    file. Returns "" when nothing has run yet."""
    import server  # lazy
    try:
        if source == "pe":
            cands: list[Path] = []
            for base in (server.PE_PANEL_LOGS, server.PE_ROOT):
                if base and base.exists():
                    cands += list(base.glob("*.log"))
            if cands:
                return max(cands, key=lambda x: x.stat().st_mtime).name
        elif source == "dp":
            if server.DP_METRICS.exists():
                cands = list(server.DP_METRICS.glob("*.jsonl"))
                if cands:
                    return max(cands, key=lambda x: x.stat().st_mtime).name
        elif source == "dp_cf":
            dp_runs = getattr(server, "DP_RUNS", None)
            if dp_runs and Path(dp_runs).exists():
                dirs = list(Path(dp_runs).glob("dp_cf_*"))
                if dirs:
                    return max(dirs, key=lambda x: x.stat().st_mtime).name
    except Exception:  # noqa: BLE001
        pass
    return ""


def _roadmap_metric_value(metric: str, file: str = "") -> tuple[Optional[float], str]:
    """Live value of a roadmap metric, read from REAL eval output. Returns
    (value, detail); value=None => not measurable yet (no run / unparsable)."""
    source = _ROADMAP_METRICS.get(metric)
    if not source:
        return None, f"未知指标 {metric}(可用: {','.join(_ROADMAP_METRICS)})"
    f = file or _roadmap_latest_file(source)
    if not f:
        return None, f"{metric}: 找不到可读 run(还没跑过?)"
    try:
        if source in ("pe", "dp"):
            am = _analyze_metrics(source, f)
            if not am.get("ok"):
                return None, f"{metric}: {am.get('error')}"
            if metric == "extinct":
                return float(am.get("extinct_hits") or 0), f"{f}:extinct_hits"
            t = am.get(metric) or {}
            v = t.get("recent")
            return (float(v) if v is not None else None), f"{f}:{metric}.recent={v}"
        if source == "dp_cf":
            a = _analyze_dp_counterfactual(file=f)
            if not a.get("ok"):
                return None, f"understanding_dp: {a.get('error')}"
            return (float(a.get("understanding_score") or 0),
                    f"{f}:understanding={a.get('understanding_score')}")
        if source == "mem":
            a = _analyze_memory_ablation(file=f)
            if not a.get("ok"):
                return None, f"understanding_mem: {a.get('error')}"
            return (float(a.get("understanding_score") or 0),
                    f"understanding_mem={a.get('understanding_score')}")
    except Exception as e:  # noqa: BLE001
        return None, f"{metric}: 读取异常 {e}"
    return None, f"{metric}: 无法解析"


def _clause_target(clause: dict[str, Any], baseline: Optional[float]) -> Optional[float]:
    """Effective target: absolute `target`, else `rel` over a captured baseline
    (rel=0.15 => baseline*1.15; works for both raise/lower since op decides)."""
    if clause.get("target") is not None:
        return float(clause["target"])
    rel = clause.get("rel")
    if rel is not None and baseline is not None:
        return float(baseline) * (1.0 + float(rel))
    return None


def _clause_eval(clause: dict[str, Any], value: Optional[float],
                 target: Optional[float]) -> tuple[bool, bool, float]:
    """(ok, near, progress0..1) for one clause.
    ok = strictly met. near = within tolerance but not strictly met.
    progress = smooth fill for the slider."""
    op = clause.get("op", ">=")
    if value is None or target is None:
        return False, False, 0.0
    # Compute tolerance band
    tol = max(abs(target) * _NEAR_MET_TOLERANCE, _NEAR_MET_MIN_ABS) if target else _NEAR_MET_MIN_ABS
    if op in (">=", ">"):
        ok = value >= target if op == ">=" else value > target
        near = (not ok) and (value >= target - tol)
        prog = 1.0 if ok else (max(0.0, value) / target if target > 0 else 0.0)
    else:  # "<=", "<"
        ok = value <= target if op == "<=" else value < target
        near = (not ok) and (value <= target + tol)
        prog = 1.0 if ok else (target / value if value > 0 else 0.0)
    return ok, near, max(0.0, min(1.0, prog))


def _roadmap_eval_goal(goal: dict[str, Any]) -> dict[str, Any]:
    """Evaluate ALL clauses of one goal vs live metrics (PURE read). Returns
    {met, near_met, progress, clauses:[{metric,op,target,value,ok,near,detail,trend}]}.
    near_met = all clauses are either ok or within tolerance."""
    clauses = goal.get("acceptance") or []
    if not clauses:
        return {"met": False, "near_met": False, "progress": 0.0, "clauses": [],
                "note": "无验收子句(至少给一条 metric/op/target)"}
    base = goal.get("baseline") or {}
    history = goal.get("value_history") or {}
    out: list[dict[str, Any]] = []
    progs: list[float] = []
    all_ok = True
    all_near_or_ok = True
    for i, c in enumerate(clauses):
        key = c.get("metric", f"c{i}")
        tgt = _clause_target(c, base.get(key))
        val, detail = _roadmap_metric_value(c.get("metric", ""), c.get("file", ""))
        ok, near, prog = _clause_eval(c, val, tgt)
        all_ok = all_ok and ok
        all_near_or_ok = all_near_or_ok and (ok or near)
        progs.append(prog)
        # Trend: compare to recent history
        trend = _compute_trend(history.get(key, []), val)
        out.append({"metric": c.get("metric"), "op": c.get("op", ">="),
                    "target": tgt, "value": val, "ok": ok, "near": near,
                    "detail": detail, "trend": trend})
    return {"met": all_ok, "near_met": (not all_ok) and all_near_or_ok,
            "progress": round(sum(progs) / len(progs), 3),
            "clauses": out}


def _compute_trend(history: list, current_val) -> str:
    """Compute trend direction from recent metric history.
    Returns 'up', 'down', or 'flat'."""
    if current_val is None or not history:
        return "flat"
    recent = [v for v in history[-3:] if v is not None]
    if not recent:
        return "flat"
    avg_recent = sum(recent) / len(recent)
    if abs(avg_recent) < 1e-9:
        return "up" if current_val > 0 else "flat"
    delta_pct = (current_val - avg_recent) / max(abs(avg_recent), 1e-9)
    if delta_pct > 0.02:
        return "up"
    elif delta_pct < -0.02:
        return "down"
    return "flat"


def _update_value_history(goal: dict[str, Any], clauses_eval: list) -> None:
    """Append current metric values to per-goal history (keep last 10)."""
    history = goal.setdefault("value_history", {})
    for ce in clauses_eval:
        key = ce.get("metric")
        if key:
            h = history.setdefault(key, [])
            h.append(ce.get("value"))
            if len(h) > 10:
                history[key] = h[-10:]


def _roadmap_validate_goal(g: dict[str, Any]) -> Optional[str]:
    """Return an error string if a goal is malformed, else None."""
    if not (g.get("title") or "").strip():
        return "目标缺 title"
    clauses = g.get("acceptance")
    if not isinstance(clauses, list) or not clauses:
        return f"目标『{g.get('title')}』缺 acceptance(至少一条 metric/op/target)"
    for c in clauses:
        if c.get("metric") not in _ROADMAP_METRICS:
            return (f"目标『{g.get('title')}』metric={c.get('metric')} 不支持;"
                    f"可用: {','.join(_ROADMAP_METRICS)}")
        if c.get("op", ">=") not in _ROADMAP_OPS:
            return f"目标『{g.get('title')}』op={c.get('op')} 非法(用 >=,<=,>,<)"
        if c.get("target") is None and c.get("rel") is None:
            return f"目标『{g.get('title')}』子句要给 target(绝对)或 rel(相对基线)"
    return None


def _roadmap_capture_baseline(g: dict[str, Any]) -> None:
    """Snapshot the current value of every metric a goal references, so `rel`
    clauses (相对基线提升 X%) have a fixed reference from goal-creation time."""
    base: dict[str, Any] = {}
    for c in g.get("acceptance") or []:
        m = c.get("metric")
        if m and m not in base:
            v, _ = _roadmap_metric_value(m, c.get("file", ""))
            base[m] = v
    g["baseline"] = base


def _roadmap_tick(cfg: dict[str, Any]) -> dict[str, Any]:
    """Heartbeat: re-evaluate every goal from live metrics and enforce Model-A
    semantics (joint completion + attack order + regression alarm + stall guard),
    persist, and return a COMPACT summary for the wake snapshot. Sets 'met' ONLY
    from measured numbers — the LLM cannot fake completion."""
    rm = _load_roadmap()
    goals = rm.get("goals") or []
    if not rm.get("active") or not goals:
        return {"active": bool(rm.get("active")), "has_goals": bool(goals),
                "complete": False, "objective": rm.get("objective", ""),
                "hint": ("还没有活跃 roadmap。开工前先用 plan_roadmap 把整条路线"
                         "(每个目标带可量化验收 metric/op/target)规划出来再动手。"
                         if not goals else "roadmap 已暂停(active=false)。")}
    goals.sort(key=lambda g: g.get("order", 0))
    hold_window = int(rm.get("hold_window", 2) or 2)
    stall_after = int(rm.get("stall_after", 6) or 6)
    events: list[str] = []
    # 1) evaluate every goal from live metrics; track stall + regression + trend
    for g in goals:
        ev = _roadmap_eval_goal(g)
        prev = g.get("status", "pending")
        g["progress"] = ev["progress"]
        g["last_clauses"] = ev["clauses"]
        _update_value_history(g, ev["clauses"])
        if ev["met"]:
            g["stall"] = {"checks": 0, "best": ev["progress"]}
            if prev != "met":
                events.append(f"达标:{g.get('title')}")
            g["status"] = "met"
        elif ev.get("near_met"):
            # Near-met: within tolerance but not strictly met.
            # Don't reset stall — keep tracking, but mark the card so the UI
            # shows a softer "almost there" state. If improving, be patient.
            if prev == "met":
                events.append(f"回退(接近达标线):{g.get('title')} 微幅滑出")
            if g.get("status") != "blocked":
                st = g.setdefault("stall", {"checks": 0, "best": None})
                best = st.get("best")
                if best is None or ev["progress"] > float(best) + 1e-3:
                    st["best"] = ev["progress"]
                    st["checks"] = 0
                else:
                    # Near-met cards get a longer stall budget (1.5x)
                    st["checks"] = int(st.get("checks", 0)) + 1
                g["status"] = "near_met"
        else:
            if prev == "met":
                events.append(f"回退(打地鼠预警):{g.get('title')} 掉出达标线")
            if g.get("status") != "blocked":
                st = g.setdefault("stall", {"checks": 0, "best": None})
                best = st.get("best")
                if best is None or ev["progress"] > float(best) + 1e-3:
                    st["best"] = ev["progress"]
                    st["checks"] = 0
                else:
                    st["checks"] = int(st.get("checks", 0)) + 1
                g["status"] = "pending"
    # 2) stall -> blocked (but near_met cards get 1.5x stall budget)
    for g in goals:
        effective_stall = stall_after
        if g.get("status") == "near_met":
            effective_stall = int(stall_after * 1.5)
        if g.get("status") in ("pending", "near_met") and \
                int(g.get("stall", {}).get("checks", 0)) >= effective_stall:
            # Check trend before marking blocked — if improving, give more time
            has_uptrend = any(
                ce.get("trend") == "up"
                for ce in g.get("last_clauses", [])
                if not ce.get("ok")
            )
            if has_uptrend and int(g.get("stall", {}).get("checks", 0)) < effective_stall * 2:
                events.append(f"仍在改善中:{g.get('title')} 指标有上升趋势,继续观察")
                continue
            g["status"] = "blocked"
            diag = (f"进度连续 {effective_stall} 次零改进,疑似撞机制天花板。"
                    "建议交维护者评估机制级改动;本卡先挂起。")
            g["blocked_reason"] = diag
            events.append(f"受阻·需关注:{g.get('title')} — {diag}")
    # 3) attack target = highest-order card that is neither met nor blocked
    #    near_met cards are also pushable (they're close, keep going)
    attack = next((g for g in goals
                   if g.get("status") not in ("met", "blocked")), None)
    for g in goals:
        if g is attack:
            g["status"] = "active"
        elif g.get("status") == "active":
            g["status"] = "pending"
    # 4) joint completion: near_met counts as met for completion check
    #    (within tolerance = good enough to declare overall success)
    blocked_n = sum(1 for g in goals if g.get("status") == "blocked")
    actionable = [g for g in goals if g.get("status") != "blocked"]
    if rm.get("stall_policy") == "hold" and blocked_n:
        all_met = False
    else:
        all_met = bool(actionable) and all(
            g.get("status") in ("met", "near_met")
            for g in actionable
        )
    rm["all_met_streak"] = int(rm.get("all_met_streak", 0)) + 1 if all_met else 0
    complete = rm["all_met_streak"] >= hold_window
    if complete and rm.get("active"):
        rm["active"] = False
        rm["completed_at"] = time.time()
        events.append("roadmap 全部达标且稳住,主线完成。")
        _timeline("roadmap_done", objective=rm.get("objective"))
    rm["goals"] = goals
    _save_roadmap(rm)
    for e in events:
        _timeline("roadmap_event", text=e)
    return {"active": rm.get("active"), "objective": rm.get("objective", ""),
            "complete": complete, "all_met_streak": rm["all_met_streak"],
            "hold_window": hold_window,
            "attack": (attack or {}).get("id"),
            "attack_title": (attack or {}).get("title"),
            "blocked": [g.get("title") for g in goals
                        if g.get("status") == "blocked"],
            "near_met": [g.get("title") for g in goals
                         if g.get("status") == "near_met"],
            "events": events,
            "goals": [{"id": g.get("id"), "title": g.get("title"),
                       "project": g.get("project"), "status": g.get("status"),
                       "progress": g.get("progress", 0.0),
                       "order": g.get("order", 0),
                       "trend": _goal_overall_trend(g)} for g in goals],
            "hint": ("照主攻顺序推进 attack 那张卡;别的卡也盯着别回退。"
                     "所有(非受阻)卡同时达标并稳住 hold_window 次才算完成。"
                     "接近达标(near_met)的卡也算达标,但仍需稳住。")}


def _roadmap_summary(rm: dict[str, Any]) -> dict[str, Any]:
    """Full read-only view (incl. per-clause detail + trend) for tools / HTTP board."""
    return {"active": rm.get("active"), "objective": rm.get("objective", ""),
            "hold_window": rm.get("hold_window"),
            "stall_after": rm.get("stall_after"),
            "stall_policy": rm.get("stall_policy"),
            "all_met_streak": rm.get("all_met_streak", 0),
            "completed_at": rm.get("completed_at"),
            "goals": [{"id": g.get("id"), "title": g.get("title"),
                       "detail": g.get("detail", ""), "project": g.get("project"),
                       "order": g.get("order", 0), "owner": g.get("owner", "agent"),
                       "status": g.get("status", "pending"),
                       "progress": g.get("progress", 0.0),
                       "acceptance": g.get("acceptance", []),
                       "baseline": g.get("baseline", {}),
                       "blocked_reason": g.get("blocked_reason", ""),
                       "clauses": g.get("last_clauses", []),
                       "trend": _goal_overall_trend(g)}
                      for g in sorted(rm.get("goals", []),
                                      key=lambda g: g.get("order", 0))]}


def _goal_overall_trend(g: dict[str, Any]) -> str:
    """Aggregate trend from all clauses of a goal."""
    clauses = g.get("last_clauses") or []
    trends = [c.get("trend", "flat") for c in clauses if not c.get("ok")]
    if not trends:
        return "flat"
    ups = sum(1 for t in trends if t == "up")
    downs = sum(1 for t in trends if t == "down")
    if ups > downs:
        return "up"
    elif downs > ups:
        return "down"
    return "flat"


def _roadmap_set_goals(rm: dict[str, Any], goals_in: list[dict[str, Any]],
                       owner: str) -> tuple[bool, str]:
    """Validate + install a fresh ordered goal list (used by plan_roadmap and the
    HTTP board). Captures baselines for `rel` clauses. Returns (ok, error)."""
    if not isinstance(goals_in, list) or not goals_in:
        return False, "goals 需为非空数组"
    new_goals: list[dict[str, Any]] = []
    for i, gi in enumerate(goals_in):
        err = _roadmap_validate_goal(gi)
        if err:
            return False, err
        gid = gi.get("id") or f"g{i + 1}"
        g = {"id": gid, "title": gi.get("title", "").strip(),
             "detail": gi.get("detail", ""), "project": gi.get("project", "any"),
             "order": int(gi.get("order", i)), "owner": gi.get("owner", owner),
             "status": "pending", "progress": 0.0,
             "acceptance": gi.get("acceptance"),
             "stall": {"checks": 0, "best": None}}
        _roadmap_capture_baseline(g)
        new_goals.append(g)
    rm["goals"] = new_goals
    rm["all_met_streak"] = 0
    return True, ""


def _roadmap_merge_goals(rm: dict[str, Any], goals_in: list[dict[str, Any]],
                         owner: str) -> tuple[bool, str]:
    """Install a full ordered goal list (from the web board) while PRESERVING
    per-card runtime state (status/progress/baseline/stall) for cards whose id
    survives AND whose acceptance is unchanged. New cards or changed acceptance
    => fresh baseline + reset status. Array order becomes the attack order."""
    if not isinstance(goals_in, list):
        return False, "goals 需为数组"
    old = {g.get("id"): g for g in rm.get("goals", [])}
    merged: list[dict[str, Any]] = []
    for i, gi in enumerate(goals_in):
        err = _roadmap_validate_goal(gi)
        if err:
            return False, err
        gid = gi.get("id") or f"g{int(time.time() * 1000) % 100000}_{i}"
        prev = old.get(gid)
        g = {"id": gid, "title": gi.get("title", "").strip(),
             "detail": gi.get("detail", ""), "project": gi.get("project", "any"),
             "order": i, "owner": (prev or {}).get("owner", gi.get("owner", owner)),
             "acceptance": gi.get("acceptance")}
        unchanged = bool(prev) and json.dumps(prev.get("acceptance"),
                                              sort_keys=True) == \
            json.dumps(gi.get("acceptance"), sort_keys=True)
        if unchanged:
            g["status"] = prev.get("status", "pending")
            g["progress"] = prev.get("progress", 0.0)
            g["baseline"] = prev.get("baseline", {})
            g["stall"] = prev.get("stall", {"checks": 0, "best": None})
            g["last_clauses"] = prev.get("last_clauses", [])
            if prev.get("blocked_reason"):
                g["blocked_reason"] = prev["blocked_reason"]
        else:
            g["status"] = "pending"
            g["progress"] = 0.0
            g["stall"] = {"checks": 0, "best": None}
            _roadmap_capture_baseline(g)
        merged.append(g)
    rm["goals"] = merged
    return True, ""


TUNE_PATH = AGENT_DIR / "agent_tunes.json"


def _load_tunes() -> list[dict[str, Any]]:
    if TUNE_PATH.exists():
        try:
            data = json.loads(TUNE_PATH.read_text(encoding="utf-8"))
            return data if isinstance(data, list) else []
        except Exception:  # noqa: BLE001
            return []
    return []


def _save_tunes(tunes: list[dict[str, Any]]) -> None:
    TUNE_PATH.write_text(json.dumps(tunes, ensure_ascii=False, indent=2),
                         encoding="utf-8")


def _campaign_launch_stage(camp: dict[str, Any], cfg: dict[str, Any]) -> dict[str, Any]:
    """Launch the campaign's CURRENT stage. Campaign launches bypass the
    new-bloodline approval gate (the staged ladder + health gates ARE the
    safety mechanism), but the resource guard (procs/disk/VRAM) still applies.
    DP carries its produced checkpoint forward on promote; PE re-runs longer
    from the base config (population-based: smoke is a viability probe)."""
    import server
    refusal = _guard_launch(cfg)
    if refusal:
        return {"ok": False, "refused": True, "reason": refusal}
    tc = cfg.get("tier_c", {})
    stage = camp["stages"][camp["stage_idx"]]
    scale = _campaign_stages(camp["project"], tc).get(stage)
    tag = f"camp{camp['id']}_{stage}"
    if camp["project"] == "dp":
        res = server.dp_train(server.DPTrainReq(
            checkpoint=camp.get("base_checkpoint"),
            seed=int(camp.get("seed") or 24), steps=int(scale),
            n_envs=int(camp.get("n_envs") or 4), tag=tag,
            reason=f"[campaign {camp['id']}] stage={stage} steps={scale}",
            purpose=camp.get("goal")))
        camp["last_run_file"] = res.get("metrics")
    else:
        res = server.pe_train(server.PETrainReq(
            config=camp["base_config"], seed=camp.get("seed"),
            resume_checkpoint=camp.get("base_checkpoint"),
            generations=int(scale),
            reason=f"[campaign {camp['id']}] stage={stage} gens={scale}",
            purpose=camp.get("goal")))
        camp["last_run_file"] = os.path.basename(res.get("log") or "") or None
    camp["last_run_id"] = res.get("run_id")
    camp["status"] = "running"
    STATE.stats["actions"] += 1
    _timeline("campaign_launch", id=camp["id"], project=camp["project"],
              stage=stage, scale=scale, run_id=res.get("run_id"))
    return res


def _campaign_advance(cid: str, cfg: dict[str, Any]) -> dict[str, Any]:
    """Evaluate the just-finished stage and act: promote / extend / revert /
    done / stop. The verdict is decided in code from the stage's metrics."""
    import server
    camps = _load_campaigns()
    camp = _find_campaign(camps, cid)
    if not camp:
        return {"ok": False, "error": f"未找到 campaign {cid}"}
    if camp["status"] in ("done", "stopped"):
        return {"ok": False, "error": f"campaign {cid} 已结束({camp['status']})"}
    live = {p.get("run_id") for p in (server.processes().get("processes") or [])}
    if camp.get("last_run_id") in live:
        return {"ok": False, "error": "当前阶段仍在训练,等它结束(或先 stop_training)再 advance。"}
    am = _analyze_metrics(camp["project"], camp.get("last_run_file") or "", 0)
    at_final = camp["stage_idx"] >= len(camp["stages"]) - 1
    verdict, vreason = _campaign_verdict(camp["project"], am, at_final=at_final)
    stage = camp["stages"][camp["stage_idx"]]
    camp.setdefault("history", []).append(
        {"stage": stage, "file": camp.get("last_run_file"), "verdict": verdict,
         "reason": vreason, "hint": am.get("hint"),
         "panorama": am.get("panorama"), "ts": time.time()})
    launched: Optional[dict[str, Any]] = None
    if verdict == "promote":
        if camp["project"] == "dp" and camp.get("last_run_file"):
            camp["base_checkpoint"] = ("checkpoints/"
                                       + camp["last_run_file"].replace(".jsonl", ".pt"))
        camp["stage_idx"] += 1
        res = _campaign_launch_stage(camp, cfg)
        if not res.get("ok"):
            camp["stage_idx"] -= 1
            camp["status"] = "held"
            _save_campaigns(camps)
            return {"ok": False, "verdict": verdict, "reason": vreason,
                    "launch_refused": res.get("reason"), "campaign": camp}
        launched = {"stage": camp["stages"][camp["stage_idx"]],
                    "run_id": res.get("run_id")}
    elif verdict == "extend":
        if int(camp.get("extends", 0)) >= int(cfg.get("tier_c", {})
                                               .get("campaign_max_extends", 1)):
            camp["status"] = "stopped"
            vreason += "(已达延长上限,停止待人工)"
        else:
            camp["extends"] = int(camp.get("extends", 0)) + 1
            res = _campaign_launch_stage(camp, cfg)
            if res.get("ok"):
                launched = {"stage": stage, "run_id": res.get("run_id"),
                            "re_extend": True}
            else:
                camp["status"] = "held"
    elif verdict == "revert":
        camp["stage_idx"] = max(0, camp["stage_idx"] - 1)
        camp["status"] = "reverted"       # hold at last good stage; no auto-escalation
    else:                                  # done | stop
        camp["status"] = "done" if verdict == "done" else "stopped"
    _save_campaigns(camps)
    _timeline("campaign_advance", id=cid, from_stage=stage, verdict=verdict,
              status=camp["status"], launched=launched,
              panorama=am.get("panorama"))
    return {"ok": True, "verdict": verdict, "reason": vreason,
            "status": camp["status"], "stage_idx": camp["stage_idx"],
            "launched": launched, "hint": am.get("hint"),
            "panorama": am.get("panorama"), "campaign": camp}


# ----- bounded closed-loop reward/evo auto-tune (③, PE safe-zone only) ----- #
def _tune_candidate_is_safe(config: str, knob: str, value: Any,
                            pct_limit: float) -> tuple[bool, str]:
    """A tune candidate is allowed autonomously only if it stays in the tier-C
    LOW-risk zone (same sign, |Δ|/old <= pct_limit, numeric, no add/remove).
    Uses the server pe_tune dry_run for the authoritative old->new delta."""
    import server
    try:
        res = server.pe_tune(server.PETuneReq(
            config=config, edits={knob: value}, label="tune_probe", dry_run=True))
    except Exception as e:  # noqa: BLE001
        return False, f"无法核验改动安全性(dry_run 失败:{e})"
    for a in (res.get("applied") or []):
        if _delta_is_structural(a.get("delta") or {}, pct_limit):
            return False, f"{a.get('knob')} 是结构性改动(变号/幅度>{int(pct_limit*100)}%/增删项)——超出自动调参安全域"
    return True, ""


def _tune_pick_winner(project: str, cmp: dict[str, Any]) -> Optional[str]:
    """Pick the winning run file from a compare_runs result. PURE.
    PE ranks by avg_recent then qd_recent; DP by score/reward recent. Runs with
    any extinction or a parse error are disqualified."""
    rows = [r for r in (cmp.get("rows") or []) if r.get("ok")]
    if project == "pe":
        rows = [r for r in rows if not (r.get("extinct_hits") or 0)]
        key = lambda r: ((r.get("avg_recent") if r.get("avg_recent") is not None else -1e9),
                         (r.get("qd_recent") if r.get("qd_recent") is not None else -1e9))
    else:
        key = lambda r: ((r.get("score_recent") if r.get("score_recent") is not None else -1e9),
                         (r.get("reward_recent") if r.get("reward_recent") is not None else -1e9))
    if not rows:
        return None
    return max(rows, key=key).get("file")


# ----- vetted-ladder curriculum advance (② autonomy within a pre-vetted path) #
CURRICULUM_STATE_PATH = AGENT_DIR / "agent_curriculum_state.json"


def _load_curriculum_ladder() -> Optional[dict[str, Any]]:
    """A HUMAN-authored, pre-vetted curriculum ladder. Its presence is what
    lets the agent advance curriculum autonomously (within this fixed path);
    without it, curriculum edits stay human-gated. Schema:
      {"stages": [{"name": str, "edits": {dotted_knob: value, ...}}, ...]}"""
    if not CURRICULUM_LADDER_PATH.exists():
        return None
    try:
        data = json.loads(CURRICULUM_LADDER_PATH.read_text(encoding="utf-8"))
    except Exception:  # noqa: BLE001
        return None
    stages = data.get("stages") if isinstance(data, dict) else None
    if not isinstance(stages, list) or not stages:
        return None
    return data


def _curriculum_advance(config: str, cfg: dict[str, Any], *,
                        reason: str = "") -> dict[str, Any]:
    """Advance the curriculum ONE rung along the vetted ladder, autonomously.
    Falls back to the gated pe_curriculum_edit path if no vetted ladder exists."""
    import server
    if not config:
        return {"ok": False, "error": "需要 config(当前 PE TOML)。"}
    ladder = _load_curriculum_ladder()
    if ladder is None:
        return {"ok": False, "gated": True,
                "error": ("没有预先评定的课程阶梯(curriculum_ladder.json)——"
                          "凭空改课程是最高杠杆,请走 pe_curriculum_edit 提议→人工批准。"
                          "若要开放自主推进,请人工放置 vetted 的 curriculum_ladder.json。")}
    stages = ladder["stages"]
    try:
        state = json.loads(CURRICULUM_STATE_PATH.read_text(encoding="utf-8")) \
            if CURRICULUM_STATE_PATH.exists() else {}
    except Exception:  # noqa: BLE001
        state = {}
    cur = int(state.get(config, -1))
    nxt = cur + 1
    if nxt >= len(stages):
        return {"ok": False, "error": f"课程已在阶梯顶端(stage {cur}),无更高难度可推进。"}
    stage = stages[nxt]
    edits = stage.get("edits") or {}
    if not edits:
        return {"ok": False, "error": f"阶梯 stage {nxt} 未定义 edits。"}
    res = server.pe_tune(server.PETuneReq(
        config=config, edits=edits,
        label=f"curri_{stage.get('name', nxt)}"))
    if not res.get("ok"):
        return res
    state[config] = nxt
    CURRICULUM_STATE_PATH.write_text(json.dumps(state, ensure_ascii=False, indent=2),
                                     encoding="utf-8")
    STATE.stats["actions"] += 1
    _timeline("curriculum_advance", config=config, to_stage=nxt,
              stage_name=stage.get("name"), variant=res.get("variant"))
    return {"ok": True, "advanced_to": nxt, "stage_name": stage.get("name"),
            "variant": res.get("variant"), "applied": res.get("applied"),
            "note": "已沿预设阶梯推进一档(vetted 范围内,自主)。"}


def _campaigns_awaiting_advance() -> list[dict[str, Any]]:
    """Campaigns whose current-stage run has ended but that are still 'running'
    (status not yet advanced). PURE-ish (reads campaign file + live procs)."""
    import server
    camps = _load_campaigns()
    live = {p.get("run_id") for p in (server.processes().get("processes") or [])}
    return [c for c in camps if c.get("status") == "running"
            and c.get("last_run_id") not in live]


def _watcher_campaign_selfheal(cfg: dict[str, Any]) -> str:
    """④ watcher self-heal: when a campaign's stage run ends, either auto-drive
    the code-decided next move (when autonomy_auto_advance is on) or surface a
    hint so the woken agent advances it. The verdict is always code-decided in
    _campaign_advance (extinction/decline->revert, plateau->done, up->promote)."""
    pending = _campaigns_awaiting_advance()
    if not pending:
        return ""
    auto = bool(cfg.get("autonomy_auto_advance", False))
    bits: list[str] = []
    for c in pending:
        if auto:
            res = _campaign_advance(c["id"], cfg)
            pano = res.get("panorama")
            bits.append(f"campaign {c['id']} 自动推进:{res.get('verdict')}"
                        f"({res.get('status')})"
                        + (f" | {pano}" if pano else ""))
        else:
            bits.append(f"campaign {c['id']}({c['project']},"
                        f"{c['stages'][c['stage_idx']]})的 run 已结束,待 advance_campaign")
    if auto:
        return " 自治推进:" + ";".join(bits) + "。仍请 record_gen 记台账。"
    return " " + ";".join(bits) + "。先 kb_query→record_gen,再 advance_campaign。"


def _kb_query_in_recent(msgs: list[dict[str, Any]], lookback: int = 8) -> bool:
    """True if kb_query was called within the last few messages — used to FORCE
    a knowledge lookup before any high-leverage action."""
    for m in reversed(msgs[-lookback:]):
        for tc in (m.get("tool_calls") or []):
            if (tc.get("function", {}) or {}).get("name") == "kb_query":
                return True
    return False


# Action tools that MUST be preceded by a kb_query in the same wake cycle.
_REQUIRE_KB_FIRST = {
    "start_dp_training", "start_pe_training", "make_config_variant",
    "dp_record_demos", "dp_train_bc", "dp_dagger", "dp_finetune",
    "pe_reward_tune", "pe_archive_geometry", "pe_evolution_tune",
    "pe_curriculum_edit",
    "start_campaign", "advance_campaign", "start_tune", "resolve_tune",
    "curriculum_advance",
}


# --------------------------------------------------------------------------- #
# Tool execution. Returns a JSON-serializable dict (the tool result).
# --------------------------------------------------------------------------- #
def _execute_tool(name: str, args: dict[str, Any], cfg: dict[str, Any]) -> dict[str, Any]:
    # ---- project-partition guard (code level; not left to the LLM) --------- #
    meta = TOOL_META.get(name, {})
    proj = meta.get("project")
    if name == "focus_project":
        p = args.get("project")
        if p not in ("dp", "pe"):
            return {"ok": False, "error": "project 必须是 dp 或 pe"}
        with STATE.lock:
            STATE.focus_project = p
            STATE.active_packs = set()       # packs are project-scoped
        _timeline("focus_project", project=p, reason=args.get("reason", ""))
        return {"ok": True, "focus_project": p,
                "note": f"已聚焦 {p};现在只有 {p} 的动作工具可用,另一个项目的动作工具已从工具表移除。"
                        "涉及 BC/老师/数据集/奖励/课程/档案 等长尾操作,先 find_tools 调出来。"}
    if name == "find_tools":
        return _find_tools(args.get("keyword", ""), args.get("pack", ""),
                           STATE.focus_project)
    if proj in ("dp", "pe") and STATE.focus_project != proj:
        return {"ok": False, "refused": True, "focus_required": proj,
                "error": f"拒绝执行:当前焦点={STATE.focus_project or '未设定'},而 {name} 属于 {proj} 项目。"
                         f"请先 focus_project('{proj}') 再调用——一轮决策只针对一个项目,跨项目必须串行。"}
    if proj == "shared":
        if STATE.focus_project is None:
            return {"ok": False, "refused": True,
                    "error": f"拒绝执行:{name} 需要先 focus_project(dp|pe) 设定本轮焦点。"}
        args = {**args, "project": STATE.focus_project}   # scope reads to focus
    import server
    try:
        if name == "get_status":
            return _gather_observation(cfg)
        if name == "list_pe_configs":
            return {"configs": server.pe_configs()}
        if name == "list_checkpoints":
            proj = args.get("project", "pe")
            if proj == "dp":
                return {"checkpoints": server.dp_checkpoints()}
            return {"checkpoints": server.pe_checkpoints()}
        if name == "read_log_tail":
            n = max(1, min(int(args.get("n", 40)), 200))
            rid = args.get("run_id")
            if rid and rid in server.RUNS:
                return _cap_log_lines(server.RUNS[rid].lines[-n:])
            proj = args.get("project", "pe")
            fname = args.get("file", "")
            if proj == "dp":
                p = server._dp_resolve(fname)
            else:
                p = server.PE_PANEL_LOGS / fname
                if not p.exists():
                    p = server.PE_ROOT / fname
            if not p.exists():
                return {"error": f"log not found: {fname}"}
            return _cap_log_lines(p.read_text(encoding="utf-8", errors="ignore").splitlines()[-n:])
        if name == "analyze_metrics":
            return _analyze_metrics(args.get("project", "pe"), args.get("file", ""),
                                    int(args.get("window", 0) or 0))
        if name == "compare_runs":
            return _compare_runs(args.get("project", "pe"),
                                 args.get("files") or [],
                                 int(args.get("window", 0) or 0))
        if name == "analyze_memory_ablation":
            return _analyze_memory_ablation(args.get("file", "") or "",
                                            args.get("run_id", "") or "")
        if name == "analyze_dp_counterfactual":
            return _analyze_dp_counterfactual(args.get("file", "") or "",
                                              args.get("run_id", "") or "")
        if name == "inspect_config":
            return _inspect_config(args.get("config", ""))
        if name == "make_config_variant":
            res = server.make_config_variant(
                args.get("base") or args.get("config", ""),
                args.get("knob", ""), args.get("value"))
            if res.get("ok"):
                STATE.stats["actions"] += 1
                _timeline("config_variant", base=res.get("base"),
                          variant=res.get("variant"), knob=res.get("knob"),
                          old=res.get("old_value"), new=res.get("new_value"))
            return res
        if name == "make_memory_ablation_config":
            res = server.make_memory_ablation_config(
                args.get("base") or args.get("config", ""),
                args.get("checkpoint") or None,
                int(args.get("episodes_per_task", 2) or 2))
            if res.get("ok"):
                STATE.stats["actions"] += 1
                _timeline("memory_ablation_config", base=res.get("base"),
                          config=res.get("config"),
                          checkpoint=res.get("checkpoint"),
                          episodes_per_task=res.get("episodes_per_task"))
            return res
        if name == "dp_counterfactual_probe":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            res = server.dp_counterfactual_probe(
                args.get("checkpoint", "") or "",
                int(args.get("episodes", 6) or 6),
                args.get("groups") or None,
                int(args.get("seed", 12345) or 12345),
                args.get("tag") or None,
                args.get("reason"), args.get("purpose"))
            if res.get("ok"):
                STATE.stats["actions"] += 1
                _timeline("dp_counterfactual_probe",
                          checkpoint=args.get("checkpoint"),
                          out_dir=res.get("out_dir"),
                          groups=res.get("stages"),
                          run_id=res.get("run_id"),
                          reason=args.get("reason"))
            return res
        # ---- DP long-tail pipeline (teacher -> BC -> DAgger -> PPO finetune) - #
        if name == "dp_record_demos":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            kw: dict[str, Any] = {
                "teacher": args.get("teacher", "settler"),
                "seed": int(args.get("seed", 24)), "tag": args.get("tag", "agent"),
                "oracle_hunt": bool(args.get("oracle_hunt", True)),
                "oracle_no_fire": bool(args.get("oracle_no_fire", False)),
                "reason": args.get("reason"), "purpose": args.get("purpose")}
            if args.get("steps") is not None:
                kw["steps"] = int(args["steps"])
            res = server.dp_record_demos(server.DPDemosReq(**kw))
            STATE.stats["actions"] += 1
            _timeline("dp_record_demos", teacher=kw["teacher"], seed=kw["seed"],
                      tag=kw["tag"])
            return {"ok": True, **res}
        if name == "dp_train_bc":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            kw = {"demos": args["demos"], "tag": args.get("tag", "agent"),
                  "epochs": int(args.get("epochs", 10)),
                  "batch": int(args.get("batch", 16)),
                  "bptt": int(args.get("bptt", 64)),
                  "lr": float(args.get("lr", 1e-3)),
                  "trigger_weight": float(args.get("trigger_weight", 5.0)),
                  "reason": args.get("reason"), "purpose": args.get("purpose")}
            res = server.dp_train_bc(server.DPBCReq(**kw))
            STATE.stats["actions"] += 1
            _timeline("dp_train_bc", demos=kw["demos"], tag=kw["tag"],
                      epochs=kw["epochs"])
            return {"ok": True, **res}
        if name == "dp_dagger":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            kw = {"clone": args["clone"], "seed": int(args.get("seed", 24)),
                  "tag": args.get("tag", "dagger"),
                  "oracle_hunt": bool(args.get("oracle_hunt", True)),
                  "reason": args.get("reason"), "purpose": args.get("purpose")}
            if args.get("steps") is not None:
                kw["steps"] = int(args["steps"])
            res = server.dp_dagger(server.DPDaggerReq(**kw))
            STATE.stats["actions"] += 1
            _timeline("dp_dagger", clone=kw["clone"], tag=kw["tag"])
            return {"ok": True, **res}
        if name == "dp_finetune":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            kw = {"load": args["load"], "seed": int(args.get("seed", 24)),
                  "steps": int(args.get("steps", 8_000_000)),
                  "n_envs": int(args.get("n_envs", 4)), "tag": args.get("tag", "agent"),
                  "ent_coef": float(args.get("ent_coef", 0.0015)),
                  "lr": float(args.get("lr", 1.5e-4)),
                  "critic_warmup": int(args.get("critic_warmup", 32)),
                  "reason": args.get("reason"), "purpose": args.get("purpose")}
            for k in ("hunt_shaping", "repertoire_shaping", "warmth_shaping",
                      "night_shaping", "day_shaping", "thirst_decay", "trigger_cost"):
                if args.get(k) is not None:
                    kw[k] = float(args[k])
            res = server.dp_finetune(server.DPFinetuneReq(**kw))
            STATE.stats["actions"] += 1
            _timeline("dp_finetune", load=kw["load"], tag=kw["tag"],
                      shaping={k: kw[k] for k in kw if k.endswith("shaping")})
            return {"ok": True, **res}
        # ---- PE long-tail tuning (reward / archive / evolution / curriculum) - #
        if name in ("pe_reward_tune", "pe_archive_geometry",
                    "pe_evolution_tune", "pe_curriculum_edit"):
            label = args.get("label") or name.replace("pe_", "")
            res = server.pe_tune(server.PETuneReq(
                config=args.get("config", ""), edits=args.get("edits") or {},
                label=label))
            if res.get("ok"):
                STATE.stats["actions"] += 1
                _timeline("pe_tune", tool=name, base=res.get("base"),
                          variant=res.get("variant"), applied=res.get("applied"))
            return res
        # ---- autonomous campaign controller --------------------------------- #
        if name == "start_campaign":
            proj = STATE.focus_project
            if proj not in ("dp", "pe"):
                return {"ok": False, "error": "请先 focus_project(dp|pe) 再起 campaign。"}
            base_config = args.get("config") or args.get("base_config")
            if proj == "pe" and not base_config:
                return {"ok": False, "error": "PE campaign 需要 config(.toml 基线)。"}
            camps = _load_campaigns()
            cid = datetime.now().strftime("%m%d%H%M%S")
            camp = {"id": cid, "project": proj,
                    "goal": args.get("goal") or cfg.get("objective", ""),
                    "stages": list(CAMPAIGN_STAGES), "stage_idx": 0,
                    "status": "new", "base_checkpoint": args.get("base_checkpoint"),
                    "base_config": base_config, "seed": args.get("seed"),
                    "n_envs": int(args.get("n_envs", 4) or 4), "history": [],
                    "extends": 0, "created_at": time.time(),
                    "reason": args.get("reason", "")}
            res = _campaign_launch_stage(camp, cfg)
            if not res.get("ok"):
                return res
            camps.append(camp)
            _save_campaigns(camps)
            return {"ok": True, "campaign_id": cid, "project": proj,
                    "stage": "smoke", "run_id": res.get("run_id"),
                    "metrics_file": camp.get("last_run_file"),
                    "note": ("smoke 已启动;结束后调 advance_campaign,"
                             "由代码按指标判定晋级/回退/收尾。")}
        if name == "advance_campaign":
            return _campaign_advance(args.get("campaign_id", ""), cfg)
        if name == "campaign_status":
            camps = _load_campaigns()
            return {"ok": True, "count": len(camps),
                    "campaigns": [{"id": c["id"], "project": c["project"],
                                   "stage": c["stages"][c["stage_idx"]],
                                   "stage_idx": c["stage_idx"], "status": c["status"],
                                   "goal": c.get("goal"),
                                   "last_run_file": c.get("last_run_file"),
                                   "history": c.get("history", [])}
                                  for c in camps]}
        # ---- roadmap: persistent long-horizon plan (Model A) ---------------- #
        if name == "plan_roadmap":
            rm = _roadmap_default()
            rm["objective"] = (args.get("objective") or "").strip()
            if args.get("hold_window") is not None:
                rm["hold_window"] = max(1, int(args["hold_window"]))
            if args.get("stall_after") is not None:
                rm["stall_after"] = max(1, int(args["stall_after"]))
            if args.get("stall_policy") in ("skip", "hold"):
                rm["stall_policy"] = args["stall_policy"]
            ok, err = _roadmap_set_goals(rm, args.get("goals") or [], owner="agent")
            if not ok:
                return {"ok": False, "error": err}
            rm["active"] = True
            _save_roadmap(rm)
            _timeline("roadmap_plan", objective=rm["objective"],
                      goals=len(rm["goals"]), reason=args.get("reason", ""))
            tick = _roadmap_tick(cfg)
            return {"ok": True, "objective": rm["objective"],
                    "goals": len(rm["goals"]), "tick": tick,
                    "note": "roadmap 已就位并激活;按 attack 顺序逐步推进,"
                            "所有卡同时达标并稳住才算完成。"}
        if name == "roadmap_status":
            _roadmap_tick(cfg)  # refresh from live metrics, then full read
            return {"ok": True, **_roadmap_summary(_load_roadmap())}
        if name == "roadmap_edit":
            rm = _load_roadmap()
            op = args.get("op")
            goals = rm.get("goals") or []
            if op == "add_goal":
                gi = args.get("goal") or {}
                err = _roadmap_validate_goal(gi)
                if err:
                    return {"ok": False, "error": err}
                gid = gi.get("id") or f"g{len(goals) + 1}"
                if any(g.get("id") == gid for g in goals):
                    gid = f"g{int(time.time())}"
                g = {"id": gid, "title": gi.get("title", "").strip(),
                     "detail": gi.get("detail", ""),
                     "project": gi.get("project", "any"),
                     "order": int(gi.get("order", len(goals))),
                     "owner": gi.get("owner", "agent"), "status": "pending",
                     "progress": 0.0, "acceptance": gi.get("acceptance"),
                     "stall": {"checks": 0, "best": None}}
                _roadmap_capture_baseline(g)
                goals.append(g)
            elif op == "update_goal":
                gi = args.get("goal") or {}
                gid = gi.get("id")
                tgt = next((g for g in goals if g.get("id") == gid), None)
                if not tgt:
                    return {"ok": False, "error": f"找不到卡 id={gid}"}
                for k in ("title", "detail", "project", "order"):
                    if gi.get(k) is not None:
                        tgt[k] = gi[k]
                if gi.get("acceptance") is not None:
                    tgt["acceptance"] = gi["acceptance"]
                    err = _roadmap_validate_goal(tgt)
                    if err:
                        return {"ok": False, "error": err}
                    _roadmap_capture_baseline(tgt)
                    tgt["status"] = "pending"
                    tgt["stall"] = {"checks": 0, "best": None}
            elif op == "remove_goal":
                gid = args.get("id")
                goals = [g for g in goals if g.get("id") != gid]
                rm["goals"] = goals
            elif op == "reorder":
                order = args.get("order") or []
                pos = {gid: i for i, gid in enumerate(order)}
                for g in goals:
                    if g.get("id") in pos:
                        g["order"] = pos[g["id"]]
            elif op == "reopen":
                gid = args.get("id")
                tgt = next((g for g in goals if g.get("id") == gid), None)
                if not tgt:
                    return {"ok": False, "error": f"找不到卡 id={gid}"}
                tgt["status"] = "pending"
                tgt["stall"] = {"checks": 0, "best": None}
                tgt.pop("blocked_reason", None)
            elif op == "set_objective":
                rm["objective"] = (args.get("objective") or "").strip()
            elif op == "pause":
                rm["active"] = False
            elif op == "resume":
                rm["active"] = True
            elif op == "set_policy":
                if args.get("stall_policy") in ("skip", "hold"):
                    rm["stall_policy"] = args["stall_policy"]
            else:
                return {"ok": False, "error": f"未知 op={op}"}
            rm["goals"] = goals
            _save_roadmap(rm)
            _timeline("roadmap_edit", op=op, reason=args.get("reason", ""))
            return {"ok": True, "op": op, **_roadmap_summary(_load_roadmap())}
        # ---- bounded closed-loop auto-tune (PE safe-zone) ------------------- #
        if name == "start_tune":
            if STATE.focus_project != "pe":
                return {"ok": False, "error": "auto-tune 目前支持 PE 安全域;请先 focus pe。"}
            base = args.get("config", "")
            knob = args.get("knob", "")
            values = args.get("values") or []
            if not base or not knob or not values:
                return {"ok": False, "error": "start_tune 需要 config + knob + values。"}
            pct_limit = float(cfg.get("tier_c", {}).get("reward_pct_limit", 0.25))
            max_n = max(1, int(cfg.get("max_procs", 10)) - 1)   # leave headroom
            checked: list[dict[str, Any]] = []
            for v in values[:max_n]:
                safe, why = _tune_candidate_is_safe(base, knob, v, pct_limit)
                checked.append({"value": v, "safe": safe, "why": why})
            safe_vals = [c["value"] for c in checked if c["safe"]]
            if not safe_vals:
                return {"ok": False, "error": "所有候选都超出自动调参安全域(需走 pe_reward_tune→人批)。",
                        "checked": checked}
            arms: list[dict[str, Any]] = []
            for v in safe_vals:
                refusal = _guard_launch(cfg)
                if refusal:
                    arms.append({"value": v, "launched": False, "reason": refusal})
                    continue
                var = server.make_config_variant(base, knob, v)
                if not var.get("ok"):
                    arms.append({"value": v, "launched": False, "reason": var.get("error")})
                    continue
                variant_cfg = var.get("variant")
                gens = int(cfg.get("tier_c", {}).get("pe_smoke_generations", 4))
                pr = server.pe_train(server.PETrainReq(
                    config=variant_cfg, generations=gens,
                    reason=f"[tune {knob}={v}] smoke", purpose=args.get("purpose")))
                arms.append({"value": v, "launched": True, "config": variant_cfg,
                             "run_id": pr.get("run_id"),
                             "file": os.path.basename(pr.get("log") or "") or None})
                STATE.stats["actions"] += 1
            tunes = _load_tunes()
            tid = "t" + datetime.now().strftime("%m%d%H%M%S")
            tunes.append({"id": tid, "project": "pe", "base": base, "knob": knob,
                          "status": "running", "arms": arms, "checked": checked,
                          "created_at": time.time(), "reason": args.get("reason", "")})
            _save_tunes(tunes)
            _timeline("start_tune", id=tid, knob=knob,
                      launched=[a for a in arms if a.get("launched")])
            return {"ok": True, "tune_id": tid, "knob": knob, "arms": arms,
                    "rejected": [c for c in checked if not c["safe"]],
                    "note": "各候选 smoke 已起;结束后调 resolve_tune 由代码 compare 选赢家。"}
        if name == "resolve_tune":
            tunes = _load_tunes()
            tune = next((t for t in tunes if t.get("id") == args.get("tune_id")), None)
            if not tune:
                return {"ok": False, "error": f"未找到 tune {args.get('tune_id')}"}
            if tune["status"] == "resolved":
                return {"ok": False, "error": "该批次已结算。", "tune": tune}
            live = {p.get("run_id") for p in (server.processes().get("processes") or [])}
            still = [a for a in tune["arms"]
                     if a.get("launched") and a.get("run_id") in live]
            if still:
                return {"ok": False, "error": "仍有候选在训练,等结束再 resolve。",
                        "still_running": [a["run_id"] for a in still]}
            files = [a["file"] for a in tune["arms"] if a.get("launched") and a.get("file")]
            if len(files) < 2:
                return {"ok": False, "error": "可比较的已完成候选 <2,无法选赢家。"}
            cmp = _compare_runs("pe", files, 0)
            winner = _tune_pick_winner("pe", cmp)
            tune["status"] = "resolved"
            tune["winner_file"] = winner
            tune["winner_value"] = next((a["value"] for a in tune["arms"]
                                         if a.get("file") == winner), None)
            tune["compare"] = cmp
            _save_tunes(tunes)
            _timeline("resolve_tune", id=tune["id"], knob=tune["knob"],
                      winner_value=tune.get("winner_value"), winner_file=winner)
            return {"ok": True, "tune_id": tune["id"], "knob": tune["knob"],
                    "winner_value": tune.get("winner_value"),
                    "winner_file": winner, "ranking": cmp.get("ranking"),
                    "note": "赢家变体已记台账;后续可用它做 start_campaign 的基线。"}
        # ---- vetted-ladder curriculum advance (autonomous within envelope) -- #
        if name == "curriculum_advance":
            return _curriculum_advance(args.get("config", ""), cfg,
                                       reason=args.get("reason", ""))
        if name == "start_pe_training":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            req = server.PETrainReq(config=args["config"], seed=args.get("seed"),
                                    resume_checkpoint=args.get("resume_checkpoint"),
                                    generations=args.get("generations"),
                                    reason=args.get("reason"),
                                    purpose=args.get("purpose"))
            res = server.pe_train(req)
            STATE.stats["actions"] += 1
            return {"ok": True, **res}
        if name == "start_dp_training":
            refusal = _guard_launch(cfg)
            if refusal:
                return {"ok": False, "refused": True, "reason": refusal}
            req = server.DPTrainReq(
                checkpoint=args.get("checkpoint"), seed=args.get("seed", 24),
                steps=args.get("steps", 8_000_000), n_envs=args.get("n_envs", 4),
                tag=args.get("tag", "agent"), extra_args=args.get("extra_args", ""),
                reason=args.get("reason"), purpose=args.get("purpose"))
            res = server.dp_train(req)
            STATE.stats["actions"] += 1
            return {"ok": True, **res}
        if name == "stop_training":
            req = server.StopReq(run_id=args.get("run_id"), pid=args.get("pid"))
            res = server.train_stop(req)
            STATE.stats["actions"] += 1
            return {"ok": True, **res}
        if name == "cleanup_disk":
            proj = args.get("project", "pe")
            before = (server.system_status().get("disk") or {}).get("free_gb")
            # Reuse the panel's safe log clear over discovered logs (jsonl excluded
            # by default protection; *.pt never touched). Also clear traces.
            logs = server.dp_logs() if proj == "dp" else server.pe_logs()
            names = [l["name"] for l in logs
                     if l.get("name", "").endswith(".log") and not l.get("in_use")]
            cleared = {}
            if names:
                creq = server.ClearLogsReq(project=proj, names=names, hard=False)
                cleared = server.logs_clear(creq)
            after = (server.system_status().get("disk") or {}).get("free_gb")
            STATE.stats["actions"] += 1
            return {"ok": True, "freed_gb": (after - before) if (after and before) else None,
                    "free_gb_now": after, "cleared": cleared}
        if name == "delete_checkpoint":
            names = args.get("names") or []
            if isinstance(names, str):
                names = [names]
            names = [n for n in names if n]
            if not names:
                return {"ok": False, "error": "no checkpoint names given"}
            res = server.dp_clear_checkpoints(server.DeleteReq(names=names, hard=False))
            STATE.stats["actions"] += 1
            _timeline("checkpoint_deleted", removed=res.get("removed", []),
                      skipped=res.get("skipped", []), reason=args.get("reason", ""))
            return {"ok": True, **res}
        if name == "recall_timeline":
            return _recall_timeline(int(args.get("limit", 20) or 20), args.get("kind"))
        if name == "list_docs":
            return {"docs": _list_docs()}
        if name == "read_doc":
            return _read_doc(args.get("name", ""), args.get("query"),
                             int(args.get("max_chars", 6000) or 6000))
        if name == "kb_write":
            return _kb_write(args)
        if name == "kb_query":
            return _kb_query(args)
        if name == "record_gen":
            STATE.needs_summary = False
            STATE._recorded_since_wake = True
            return _record_gen(args)
        if name == "query_gens":
            return _query_gens(args)
        if name == "use_strategy":
            sid = args.get("strategy", "")
            if sid not in STRATEGIES:
                return {"ok": False, "error": f"unknown strategy: {sid}",
                        "available": list(STRATEGIES.keys())}
            cfg["active_strategy"] = sid
            _save_config(cfg)
            s = STRATEGIES[sid]
            _timeline("strategy", strategy=sid, name=s["name"],
                      reason=args.get("reason", ""))
            return {"ok": True, "active_strategy": sid, "name": s["name"],
                    "when": s["when"], "guide": s["guide"]}
        if name == "list_strategies":
            return {"active": cfg.get("active_strategy"),
                    "strategies": [{"id": k, "name": v["name"], "when": v["when"],
                                    "guide": v["guide"]} for k, v in STRATEGIES.items()]}
        if name == "deep_think":
            cap = int(cfg.get("deep_think_rounds", 0) or 0)
            if cap <= 0:
                return {"ok": False, "error": "深度思考已禁用(上限=0)"}
            if STATE._deliberated_this_wake:
                return {"ok": False, "error": "本轮唤醒已执行过深度思考,无需重复"}
            rounds = max(1, min(int(args.get("rounds", 2)), cap))
            base_msgs = [_system_prompt(cfg)] + _safe_tail(STATE.messages)
            try:
                results = _deliberate(cfg, base_msgs, rounds)
            except Exception as e:  # noqa: BLE001
                _timeline("error", text=f"deep_think 失败: {e}")
                return {"ok": False, "error": str(e)}
            STATE._deliberated_this_wake = True
            STATE._last_deliberation = results
            blob = "\n".join(f"[第{e['round']}步·{e['label']}] {e['text']}"
                             for e in results if e.get("text"))
            return {"ok": True, "conclusion": blob[:4000]}
        if name == "sleep":
            minutes = max(1, min(int(args.get("minutes", cfg["default_sleep_min"])),
                                 cfg["max_sleep_min"]))
            STATE.sleep_until = time.time() + minutes * 60
            STATE.sleep_reason = args.get("reason", "")
            # Mid-training wake points: agent can schedule gens to auto-wake
            wake_gens = args.get("wake_at_gens") or []
            if wake_gens:
                STATE.wake_at_gens = sorted(int(g) for g in wake_gens)
                STATE._wake_gens_triggered = set()
            else:
                STATE.wake_at_gens = []
                STATE._wake_gens_triggered = set()
            STATE.status = "sleeping"
            STATE.wake_event.clear()
            _timeline("sleep", minutes=minutes, reason=args.get("reason", ""),
                      wake_at_gens=STATE.wake_at_gens or None)
            result: dict[str, Any] = {"ok": True, "sleeping_minutes": minutes}
            if STATE.wake_at_gens:
                result["wake_at_gens"] = STATE.wake_at_gens
            return result
        if name == "log_note":
            _timeline("note", level=args.get("level", "info"), text=args.get("text", ""))
            return {"ok": True}
        if name == "pin_spec":
            text = (args.get("text") or "").strip()
            if not text:
                return {"ok": False, "error": "empty spec"}
            specs = cfg.setdefault("pinned_specs", [])
            if text not in specs:
                specs.append(text)
            # cap so the always-present block stays bounded
            if len(specs) > 40:
                del specs[: len(specs) - 40]
            _save_config(cfg)
            _timeline("spec_pinned", text=text, count=len(specs))
            return {"ok": True, "pinned_count": len(specs)}
    except HTTPException as e:
        return {"ok": False, "error": f"{e.status_code}: {e.detail}"}
    except Exception as e:  # noqa: BLE001
        return {"ok": False, "error": str(e)}
    return {"ok": False, "error": f"unknown tool {name}"}


# --------------------------------------------------------------------------- #
# OpenAI-compatible chat call (stdlib urllib; no extra deps).
# --------------------------------------------------------------------------- #
def _chat(cfg: dict[str, Any], messages: list[dict[str, Any]]) -> dict[str, Any]:
    prov = _active_provider(cfg)
    if not prov:
        raise RuntimeError("no active model provider configured")
    url = prov["base_url"].rstrip("/") + "/chat/completions"
    body = {
        "model": prov["model"],
        "messages": messages,
        "tools": _tool_schemas(),
        "tool_choice": "auto",
        "temperature": cfg.get("temperature", 0.3),
        "max_tokens": cfg.get("max_tokens", 900),
    }
    body["stream"] = True
    body["stream_options"] = {"include_usage": True}
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(url, data=data, method="POST", headers={
        "Content-Type": "application/json",
        "Authorization": "Bearer " + prov.get("api_key", ""),
    })
    content_parts: list[str] = []
    reasoning_parts: list[str] = []
    tool_map: dict[int, dict[str, Any]] = {}
    usage: dict[str, Any] = {}
    interrupted = False
    STATE.stream_reset()
    try:
        with urllib.request.urlopen(req, timeout=180) as resp:
            for raw in resp:                      # SSE: one "data: {...}" per line
                # Abort-signal: a new user message (or stop) cuts the stream so
                # the agent can re-plan immediately instead of finishing a now-
                # stale generation. Partial tool calls are discarded by caller.
                if _should_abort():
                    interrupted = True
                    break
                line = raw.decode("utf-8", "replace").strip()
                if not line or line.startswith(":"):
                    continue
                if line.startswith("data:"):
                    line = line[5:].strip()
                if line == "[DONE]":
                    break
                try:
                    o = json.loads(line)
                except Exception:  # noqa: BLE001
                    continue
                if o.get("usage"):
                    usage = o["usage"]
                ch = o.get("choices") or []
                if not ch:
                    continue
                d = ch[0].get("delta") or {}
                rc = d.get("reasoning_content")
                if rc:
                    reasoning_parts.append(rc)
                    STATE.stream_update(reasoning=rc, phase="thinking")
                c = d.get("content")
                if c:
                    content_parts.append(c)
                    STATE.stream_update(content=c, phase="replying")
                for tcd in (d.get("tool_calls") or []):
                    idx = tcd.get("index", 0)
                    slot = tool_map.setdefault(idx, {"id": "", "type": "function",
                        "function": {"name": "", "arguments": ""}})
                    if tcd.get("id"):
                        slot["id"] = tcd["id"]
                    fnd = tcd.get("function") or {}
                    if fnd.get("name"):
                        slot["function"]["name"] = fnd["name"]
                    if fnd.get("arguments"):
                        slot["function"]["arguments"] += fnd["arguments"]
                    STATE.stream_update(phase="tool:" + slot["function"]["name"])
    finally:
        STATE.stream_done()
    STATE.stats["llm_calls"] += 1
    STATE.stats["prompt_tokens"] += int(usage.get("prompt_tokens", 0) or 0)
    STATE.stats["completion_tokens"] += int(usage.get("completion_tokens", 0) or 0)
    msg: dict[str, Any] = {"role": "assistant", "content": "".join(content_parts)}
    if interrupted:
        # Discard any half-streamed tool calls (incomplete/unsafe to run) and
        # flag the turn so the loop re-plans with the new user message.
        msg["_interrupted"] = True
        return msg
    tcs = [tool_map[k] for k in sorted(tool_map)]
    if tcs:
        msg["tool_calls"] = tcs
    reasoning = "".join(reasoning_parts)
    if reasoning:
        msg["reasoning_content"] = reasoning
    return msg


def _cognition_block(cfg: dict[str, Any]) -> str:
    """PROJECT / TOOL / SELF / BEHAVIOR cognition — gives the agent an explicit
    model of the two projects, its own partitioned tool network, the one-project
    -per-decision rule, and the forced kb_query / record_gen behavior. Dynamic
    parts (current focus + activated packs) reflect live STATE."""
    focus = STATE.focus_project
    packs = sorted(STATE.active_packs)
    pct = int(float(cfg.get("tier_c", {}).get("reward_pct_limit", 0.25)) * 100)
    focus_line = (f"当前焦点: 【{focus}】(只有 {focus} 的动作工具在工具表里)"
                  if focus else "当前焦点: 【未设定】——动作前必须先 focus_project(dp|pe)")
    pack_line = (f"已激活长尾工具包: {packs}" if packs
                 else "尚未激活任何长尾工具包(需要时 find_tools 调出)")
    return f"""
# 项目认知 (两个项目是两种完全不同的范式,别混)
- **DP (deep_protagonist)**: 单体生存,梯度训练(PPO)。奖励涨=变好,直观。
  能力链(全是已有 CLI,不改源码/维度):造老师(settler oracle)→录数据集(dp_record_demos)
  →行为克隆(dp_train_bc)→DAgger 纠偏(dp_dagger)→PPO 微调(dp_finetune,可带势能塑形系数)。
  红线:不加击杀赏金这类改奖励【结构】的(D-064 实测狩猎崩到 0,Goodhart)。势能塑形(*-shaping)是 policy-invariant 的安全杠杆,可调。
- **PE (protagonist_ecology)**: 种群进化,MAP-Elites 质量多样性(不是梯度)。维护一个"行为格子档案",
  进步=填满更多格子+每格精英更强,不是单一分数爬升。几乎一切都在 TOML:奖励/惩罚、进化引擎、课程、档案几何。
  关键坑(务必记住):**档案几何决定它像"有章法"还是"凭运气撞"**——格子开太多(如 8×8×3=192)只填 0.5~3%(维度灾难);
  2D(5×5=25)gen30 能填 20%。改参难突破多半是撞了振幅平台期,要换杠杆别死磕单旋钮。

# 工具认知 (混合工具网络:常驻核心 + 长尾工具网络)
- 常驻核心(项目无关,永远可用):get_status(全局感知两边)、focus_project、find_tools、
  kb_query/kb_write、record_gen/query_gens、use_strategy、sleep、log_note、pin_spec、recall_timeline、deep_think、读文档。
- 项目专属动作工具只在对应焦点下出现;长尾强力工具(BC/老师/DAgger/微调/奖励/档案/进化/课程)默认【藏起来】,
  用 find_tools(关键词或 pack) 把它们【激活】——激活后它们带类型化参数出现在下一轮工具表,直接调用(不是通用 call_tool)。
  例:要做 BC,先 find_tools("bc") → 下一轮就能调 dp_record_demos/dp_train_bc 等。
- {pack_line}

# 自我认知 (一轮决策 = 一个项目,代码强制串行)
- {focus_line}
- 切项目必须显式 focus_project();切换会清空已激活的长尾包。错误焦点下调另一个项目的动作工具会被代码【拒绝】。
- 即使用户要"两个一起跑",也必须串行:focus_project(dp)→决策执行→focus_project(pe)→决策执行,绝不在同一轮混着处理两个项目。

# 行为认知 (硬规范,代码强制,不靠自觉)
- 任何高杠杆动作(启训/录数据集/BC/DAgger/微调/奖励/档案/进化/课程/做变体)前,**必须先 kb_query** 查既往坑与结论,否则被拦截。
- run 结束被唤醒后,**先 kb_query 回顾 → record_gen 记台账 → kb_write 沉淀结论**,没 record_gen 不允许 sleep。
- C 分级:低风险(势能塑形系数、seed、档案几何、用现成老师跑 BC/DAgger/微调、PE 奖励权重同号且幅度≤{pct}%)可自主跑;
  高风险(改奖励【结构】=变号/幅度>{pct}%/增删项、凭空改课程 task_templates、人工等价的【直接】全量起新血脉)无论什么模式都【只提议、挂待批】。

# 自治认知 (新:把"人批每个高杠杆动作"换成"代码强制的分级验证 + 健康门")
- **start_campaign**:你可以【自主】把一条血脉从零/基线训到收敛——但代码强制走 smoke→short→long 阶梯。
  每阶段结束后调 **advance_campaign**,由【代码】按这一阶段的指标判定 晋级/回退/延长/收尾;你无法对不合格阶段强行晋级。
  灭绝/下行→自动回退保持;平台→收尾;上行→晋级更大规模。这取代了"新血脉必须人批":阶梯+健康门就是安全机制。
- **start_tune / resolve_tune**:在同号且≤{pct}% 的安全域内对一个旋钮给几个候选→代码核验安全性→各起 smoke→compare 选赢家。让调参真正闭环收敛。
- **curriculum_advance**:仅当存在人工预先评定的课程阶梯(curriculum_ladder.json)时,可【自主】沿阶梯推进一档;没有阶梯则退回 pe_curriculum_edit(挂待批)。
- 仍然永不放开(Layer-3 人工):改 C++ 源码/观测 82 维/动作 23 维/引擎机制、奖励结构重设计、凭空发明新课程任务。
- run 结束被唤醒时:若它属于某 campaign(campaign_status 里 status=running 但进程已停),先 kb_query→record_gen→再 advance_campaign 让代码判定下一步。
"""


def _system_prompt(cfg: dict[str, Any]) -> dict[str, Any]:
    """The foundation — ALWAYS present, NEVER compressed: role + red lines +
    decision tree + objective/settings + agent-pinned specs + rolling summary
    of any compressed-out history."""
    mode = cfg.get("mode")
    mode_note = ("【请求模式】启动训练/停止等受控动作会先变成请求卡,需人工批准后才执行。"
                 if mode == "request" else
                 "【完全决策权】你的动作会自动批准并立即执行,但参数+理由都会进历史。")
    extra = (f"\n# 当前设置\n模式: {mode_note}\n并发进程上限: {cfg['max_procs']}。"
             f"磁盘低于 {cfg['disk_low_gb']}G 会强制先清理。"
             f"GPU 可用显存低于 {int(cfg.get('gpu_min_free_mb', 1500))}MB 会拒绝启动新训练(防 OOM)。\n"
             f"用户目标: {cfg.get('objective','')}\n")
    extra += _cognition_block(cfg)
    extra += "\n" + BLUEPRINT_ENDSTATE
    extra += "\n" + PROJECT_BRIEF
    specs = cfg.get("pinned_specs") or []
    if specs:
        extra += ("\n# 常驻记忆 / 你提取的关键 spec (始终有效,务必遵守)\n"
                  + "\n".join(f"- {s}" for s in specs) + "\n"
                  + "(用 pin_spec 工具补充关键结论;它们永不会被压缩。)\n")
    summ = cfg.get("rolling_summary") or ""
    if summ:
        extra += f"\n# 早期历史摘要 (较早的对话已压缩成下文,细节以此为准)\n{summ}\n"
    extra += _strategy_block(cfg)
    return {"role": "system", "content": STRATEGY_DIGEST + extra}


def _estimate_tokens(text: Optional[str]) -> int:
    """Rough token estimate that works for mixed CN/EN. CJK ≈ 1 tok/char,
    ASCII ≈ 1 tok/3.5 chars. Deliberately conservative (slightly over-counts)."""
    if not text:
        return 0
    cjk = sum(1 for ch in text if "\u4e00" <= ch <= "\u9fff")
    return int(cjk + (len(text) - cjk) / 3.5) + 1


def _msg_tokens(m: dict[str, Any]) -> int:
    t = _estimate_tokens(m.get("content"))
    for tc in (m.get("tool_calls") or []):
        fn = tc.get("function", {}) or {}
        t += _estimate_tokens(str(fn.get("arguments", ""))) + _estimate_tokens(fn.get("name")) + 8
    return t + 4  # per-message role/formatting overhead


def _safe_tail(messages: list[dict[str, Any]]) -> list[dict[str, Any]]:
    """A conversation must not start with a 'tool' message (it needs the
    assistant tool_call that precedes it)."""
    cut = list(messages)
    while cut and cut[0].get("role") == "tool":
        cut = cut[1:]
    return cut


def _chat_plain(cfg: dict[str, Any], messages: list[dict[str, Any]],
                max_tokens: int = 1200) -> str:
    """A no-tools completion (used for history compression)."""
    prov = _active_provider(cfg)
    if not prov:
        return ""
    url = prov["base_url"].rstrip("/") + "/chat/completions"
    body = {"model": prov["model"], "messages": messages,
            "temperature": 0.2, "max_tokens": max_tokens}
    req = urllib.request.Request(url, data=json.dumps(body).encode("utf-8"),
        method="POST", headers={"Content-Type": "application/json",
        "Authorization": "Bearer " + prov.get("api_key", "")})
    with urllib.request.urlopen(req, timeout=120) as resp:
        payload = json.loads(resp.read().decode("utf-8"))
    usage = payload.get("usage") or {}
    STATE.stats["llm_calls"] += 1
    STATE.stats["prompt_tokens"] += int(usage.get("prompt_tokens", 0) or 0)
    STATE.stats["completion_tokens"] += int(usage.get("completion_tokens", 0) or 0)
    return payload["choices"][0]["message"].get("content") or ""


def _chat_stream_plain(cfg: dict[str, Any], messages: list[dict[str, Any]],
                       max_tokens: int = 1500, phase: str = "thinking") -> str:
    """No-tools STREAMING completion. Streams reasoning+content into STATE.live
    (so the web UI shows the thinking live) and returns the assembled text.
    Used by the multi-round deep-think loop."""
    prov = _active_provider(cfg)
    if not prov:
        return ""
    url = prov["base_url"].rstrip("/") + "/chat/completions"
    body = {"model": prov["model"], "messages": messages, "temperature": 0.4,
            "max_tokens": max_tokens, "stream": True,
            "stream_options": {"include_usage": True}}
    req = urllib.request.Request(url, data=json.dumps(body).encode("utf-8"),
        method="POST", headers={"Content-Type": "application/json",
        "Authorization": "Bearer " + prov.get("api_key", "")})
    parts: list[str] = []
    usage: dict[str, Any] = {}
    STATE.stream_update(phase=phase)
    try:
        with urllib.request.urlopen(req, timeout=180) as resp:
            for raw in resp:
                line = raw.decode("utf-8", "replace").strip()
                if not line or line.startswith(":"):
                    continue
                if line.startswith("data:"):
                    line = line[5:].strip()
                if line == "[DONE]":
                    break
                try:
                    o = json.loads(line)
                except Exception:  # noqa: BLE001
                    continue
                if o.get("usage"):
                    usage = o["usage"]
                ch = o.get("choices") or []
                if not ch:
                    continue
                d = ch[0].get("delta") or {}
                rc = d.get("reasoning_content")
                if rc:
                    STATE.stream_update(reasoning=rc, phase=phase)
                c = d.get("content")
                if c:
                    parts.append(c)
                    STATE.stream_update(content=c, phase=phase)
    except Exception as e:  # noqa: BLE001
        return "(深度思考此轮失败: %s)" % e
    STATE.stats["llm_calls"] += 1
    STATE.stats["prompt_tokens"] += int(usage.get("prompt_tokens", 0) or 0)
    STATE.stats["completion_tokens"] += int(usage.get("completion_tokens", 0) or 0)
    return "".join(parts).strip()


# Guided deliberation steps. Each round gets a DIFFERENT prompt so the model is
# walked through real reasoning instead of one shallow pass. The last step is
# always the conclusion.
THINK_STEPS: list[tuple[str, str]] = [
    ("看清现状", "只做第一步:看清现状。把与当前决策相关的事实列清楚——机器资源(GPU/磁盘/进程数)、各 run 的指标趋势、历史台账(query_gens 印象)、当前红线约束。先不要下结论、不要给动作。"),
    ("找原因与可能性", "第二步:基于上面的现状,分析可能的原因、风险与机会,提出 2-4 个候选方向(含大致参数/旋钮方向)。先不要定。"),
    ("权衡取舍", "第三步:逐个权衡候选方向的收益/风险/对红线与资源的影响,回忆 knowledge 里的已知坑排除会踩坑的,缩小到最优的 1-2 个。"),
    ("定方案", "最后一步:给出你倾向执行的具体动作与参数,以及一句话理由。这是内部结论,先用文字说清,不要在这一步调用工具。"),
]
_THINK_DEEPEN = ("再深入", "在前面思考的基础上再深入一层:有没有被忽略的风险、更优的参数、或可借鉴的历史教训?")


def _build_think_sequence(rounds: int) -> list[tuple[str, str]]:
    rounds = max(1, min(int(rounds), 6))
    concl = THINK_STEPS[-1]
    explore = THINK_STEPS[:-1]
    if rounds == 1:
        return [concl]
    need = rounds - 1
    chosen = explore[:need]
    while len(chosen) < need:
        chosen.append(_THINK_DEEPEN)
    return chosen + [concl]


def _deliberate(cfg: dict[str, Any], base_msgs: list[dict[str, Any]],
                rounds: int) -> list[dict[str, Any]]:
    """Run multi-round guided thinking. Each round has its own context (prior
    thoughts + a step-specific prompt). Rounds are EPHEMERAL: they are streamed
    to the UI and logged to the timeline, but NOT added to STATE.messages, so
    they do not linger in the rolling context (just like normal reasoning).
    Returns list of {"round": i, "total": N, "label": str, "text": str}."""
    seq = _build_think_sequence(rounds)
    results: list[dict[str, Any]] = []
    prior_texts: list[str] = []
    for i, (label, prompt) in enumerate(seq, 1):
        msgs = list(base_msgs)
        for t in prior_texts:
            msgs.append({"role": "assistant", "content": t})
        msgs.append({"role": "user",
                     "content": f"【内部深度思考 第{i}/{len(seq)}步·{label}】(这是你的内部推演,不是给用户的回复,也不要调用工具)\n{prompt}"})
        STATE.stream_reset()
        txt = _chat_stream_plain(cfg, msgs, max_tokens=int(cfg.get("max_tokens", 2000)),
                                 phase=f"think:{i}/{len(seq)}·{label}")
        STATE.stream_done()
        txt = (txt or "").strip()
        prior_texts.append(txt)
        entry = {"round": i, "total": len(seq), "label": label, "text": txt}
        results.append(entry)
        with STATE.lock:
            STATE.live.setdefault("deliberation", []).append(entry)
        _timeline("deep_think", **entry)
        # Abort-signal: a new user message (or stop) cuts deliberation short so
        # the agent re-plans promptly instead of finishing all rounds.
        if _should_abort():
            break
    return results


def _serialize_block(msgs: list[dict[str, Any]]) -> str:
    out = []
    for m in msgs:
        role = m.get("role", "?")
        content = (m.get("content") or "")
        if len(content) > 900:
            content = content[:900] + "…(截断)"
        line = f"[{role}] {content}".strip()
        for tc in (m.get("tool_calls") or []):
            fn = tc.get("function", {}) or {}
            line += f"\n  ↳调用 {fn.get('name')}({str(fn.get('arguments',''))[:300]})"
        out.append(line)
    return "\n".join(out)


def _maybe_compress(cfg: dict[str, Any]) -> None:
    """Keep the request under context_token_budget. The system prompt (role,
    red lines, decision tree, objective, pinned specs, rolling summary) is
    ALWAYS kept and never compressed; only the oldest *dialogue* messages get
    folded into the rolling summary."""
    budget = int(cfg.get("context_token_budget", 600000))
    headroom = int(cfg.get("max_tokens", 2000)) + 3000
    sys_tokens = _msg_tokens(_system_prompt(cfg))
    avail = budget - sys_tokens - headroom
    msgs = STATE.messages
    total = sum(_msg_tokens(m) for m in msgs)
    if total <= avail or not _active_provider(cfg):
        return

    keep = max(2, int(cfg.get("keep_recent_msgs", 14)))
    # Compress in chunks until we're back under budget (cap iterations to be safe).
    for _ in range(6):
        if len(STATE.messages) <= keep:
            break
        if sum(_msg_tokens(m) for m in STATE.messages) <= avail:
            break
        split = len(STATE.messages) - keep
        # never cut between an assistant tool_call and its tool replies
        while split < len(STATE.messages) and STATE.messages[split].get("role") == "tool":
            split += 1
        old = STATE.messages[:split]
        recent = _safe_tail(STATE.messages[split:])
        if not old:
            break
        prev = cfg.get("rolling_summary", "")
        sys = {"role": "system", "content":
               "你是历史压缩器。把下面这段训练管家的对话/动作历史压成要点(中文,"
               "≤1200字):保留所有已执行动作及其参数、结果/指标、踩过的坑、未决问题、"
               "需长期记住的结论。不要遗漏关键数字。"}
        user = {"role": "user", "content":
                (f"已有摘要:\n{prev}\n\n" if prev else "")
                + "新增需要并入摘要的历史:\n" + _serialize_block(old)}
        try:
            summary = _chat_plain(cfg, [sys, user], max_tokens=1500)
        except Exception as e:  # noqa: BLE001
            _timeline("error", text=f"compress failed: {e}")
            break
        if not summary:
            break
        cfg["rolling_summary"] = summary.strip()
        STATE.messages = recent
        _save_config(cfg)
        _timeline("compress", dropped=len(old), kept=len(recent),
                  summary_chars=len(cfg["rolling_summary"]))
        sys_tokens = _msg_tokens(_system_prompt(cfg))
        avail = budget - sys_tokens - headroom


# --------------------------------------------------------------------------- #
# Interruption (abort-signal) + tool partitioning helpers (claude-code style).
# --------------------------------------------------------------------------- #
def _should_abort() -> bool:
    """Abort-signal equivalent: True when the in-flight step should be cut
    short — a NEW user message arrived (interrupt → re-plan) or the agent was
    stopped. Checked during LLM streaming and between tool calls so a running
    plan can be aborted promptly instead of finishing a now-stale batch."""
    return bool(STATE.user_inbox) or not STATE.running


def _parse_tc(tc: dict[str, Any]) -> tuple[str, dict[str, Any], str]:
    fn = tc.get("function", {}) or {}
    try:
        args = json.loads(fn.get("arguments") or "{}")
    except Exception:  # noqa: BLE001
        args = {}
    return fn.get("name", ""), args, tc.get("id", "")


def _fill_tool_results(tool_calls: list[dict[str, Any]], content: str) -> None:
    """Append a placeholder tool-result for each tool_call WITHOUT executing it.
    Every tool_call_id in an assistant turn must have a matching tool message or
    the next LLM call errors; we use this when discarding calls on interrupt or
    when pausing for human approval."""
    for tc in tool_calls:
        STATE.messages.append({"role": "tool", "tool_call_id": tc.get("id", ""),
                               "content": content})


def _run_reads_parallel(batch: list[tuple[str, dict[str, Any], str]],
                        cfg: dict[str, Any]) -> list[dict[str, Any]]:
    """Run a run of consecutive concurrency-safe read tools in parallel,
    preserving input order in the returned results."""
    if len(batch) == 1:
        nm, ar, _ = batch[0]
        return [_execute_tool(nm, ar, cfg)]
    out: list[Optional[dict[str, Any]]] = [None] * len(batch)
    with ThreadPoolExecutor(max_workers=min(4, len(batch))) as ex:
        futs = {ex.submit(_execute_tool, nm, ar, cfg): k
                for k, (nm, ar, _) in enumerate(batch)}
        for f in as_completed(futs):
            k = futs[f]
            try:
                out[k] = f.result()
            except Exception as e:  # noqa: BLE001
                out[k] = {"ok": False, "error": str(e)}
    return [o if o is not None else {"ok": False, "error": "no result"} for o in out]


def _microcompact_obs(keep_last: int = 1) -> int:
    """claude-code microcompact: collapse stale bulky [现状快照] snapshots into a
    one-line placeholder, keeping only the newest `keep_last` in full. Snapshots
    are plain user messages (no tool pairing), so shrinking them is always safe
    and keeps the rolling context cheap without dropping conversation structure."""
    idxs = [k for k, m in enumerate(STATE.messages)
            if m.get("role") == "user" and isinstance(m.get("content"), str)
            and m["content"].startswith("[现状快照]")]
    drop = idxs[:-keep_last] if keep_last > 0 else idxs
    n = 0
    for k in drop:
        STATE.messages[k]["content"] = "[现状快照·已折叠省上下文(最新快照见下文)]"
        n += 1
    return n


# --------------------------------------------------------------------------- #
# The agent loop (background thread). One LLM "step" per active iteration.
# --------------------------------------------------------------------------- #
def _do_step(cfg: dict[str, Any]) -> None:
    # Drain queued user messages into the conversation.
    if STATE.user_inbox:
        joined = "\n".join(STATE.user_inbox)
        STATE.user_inbox = []
        STATE.messages.append({"role": "user", "content": "[用户]: " + joined})
        _timeline("user_msg", text=joined)

    # Always give the model a fresh, compact observation as context. Older
    # snapshots are collapsed to a placeholder first (microcompact) so only the
    # newest full snapshot occupies real context — the live world state is in
    # this latest one, stale ones add only tokens.
    _microcompact_obs(keep_last=1)
    obs = _gather_observation(cfg)
    STATE.messages.append({"role": "user",
                           "content": "[现状快照]\n" + json.dumps(obs, ensure_ascii=False)})

    # Context budget: fold oldest dialogue into the rolling summary if needed.
    # System prompt + pinned specs are always present and never compressed.
    _maybe_compress(cfg)
    base_msgs = [_system_prompt(cfg)] + _safe_tail(STATE.messages)

    # Deep thinking is now agent-initiated: the model calls `deep_think` tool
    # when it decides a decision is complex enough. The slider sets the max cap.
    msgs = base_msgs
    try:
        reply = _chat(cfg, msgs)
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", "ignore")[:300]
        STATE.last_error = f"LLM HTTP {e.code}: {detail}"
        _timeline("error", text=STATE.last_error)
        STATE.status = "sleeping"
        STATE.sleep_until = time.time() + 120
        STATE.sleep_reason = "LLM 调用失败,稍后重试"
        STATE.wake_event.clear()
        return
    except Exception as e:  # noqa: BLE001
        STATE.last_error = f"LLM error: {e}"
        _timeline("error", text=STATE.last_error)
        STATE.status = "sleeping"
        STATE.sleep_until = time.time() + 120
        STATE.sleep_reason = "LLM 调用异常,稍后重试"
        STATE.wake_event.clear()
        return

    # Interrupted mid-stream (new user message / stop): discard this turn's
    # tool calls entirely and re-plan next step (which drains the new message).
    # We keep any partial assistant text but never the half-built tool calls.
    if reply.get("_interrupted"):
        partial = (reply.get("content") or "").strip()
        if partial:
            STATE.messages.append({"role": "assistant", "content": partial})
            _timeline("assistant", text=partial)
        _timeline("interrupted", phase="llm",
                  reason="用户消息" if STATE.user_inbox else "停止")
        if STATE.running:
            STATE.status = "active"
        return

    # Record assistant message (content + any tool calls).
    assistant_msg: dict[str, Any] = {"role": "assistant",
                                      "content": reply.get("content") or ""}
    tool_calls = reply.get("tool_calls") or []
    if tool_calls:
        assistant_msg["tool_calls"] = tool_calls
    STATE.messages.append(assistant_msg)
    # Deep-think rounds belong to the FINAL reply so they render in one bubble.
    # Intermediate tool-calling turns don't carry deliberation; we keep it
    # pending until the model emits its final (no-tool-call) reply.
    final = not tool_calls
    delib = STATE._last_deliberation if final else []
    content = reply.get("content") or ""
    reasoning = reply.get("reasoning_content") or ""
    # Summarize this turn's tool calls so the chat can show what the model
    # invoked (covers read tools too, which otherwise log no executed event).
    tc_summary = []
    for tc in tool_calls:
        nm, ar, _ = _parse_tc(tc)
        if nm:
            tc_summary.append({"name": nm, "args": ar})
    if content or reasoning or delib or tc_summary:
        _timeline("assistant", text=content, reasoning=reasoning,
                  deliberation=delib if delib else None,
                  tool_calls=tc_summary if tc_summary else None)
    if final:
        STATE._last_deliberation = []

    if not tool_calls:
        # STALL GUARD: model produced reasoning but neither spoke (empty
        # content) nor acted (no tool call) -> it planned without executing.
        # Auto-nudge it to turn the plan into tool calls in the SAME wake
        # instead of sleeping, capped per wake so a truly idle turn still
        # falls through to sleep.
        if (not content) and reasoning and STATE._autocontinue < _AUTOCONTINUE_MAX:
            STATE._autocontinue += 1
            STATE.messages.append({"role": "user", "content": (
                "[\u7ee7\u7eed] \u4f60\u4e0a\u4e00\u6b65\u53ea\u5728\u601d\u8003\u91cc\u89c4\u5212\u4e86\uff0c\u4f46\u6ca1\u6709\u53d1\u51fa\u4efb\u4f55\u5de5\u5177\u8c03\u7528\u3002"
                "\u5982\u679c\u8ba1\u5212\u9700\u8981\u6267\u884c\uff0c\u73b0\u5728\u5c31\u76f4\u63a5\u53d1\u51fa\u5bf9\u5e94\u7684\u5de5\u5177\u8c03\u7528"
                "\uff08\u5982 use_strategy / make_config_variant / start_pe_training / "
                "compare_runs \u7b49\uff09\uff0c\u628a\u5206\u6790\u2192\u51b3\u7b56\u2192\u6267\u884c\u5728\u8fd9\u4e00\u6b21\u5524\u9192\u5185\u4e00\u53e3\u6c14\u505a\u5b8c\uff1b"
                "\u82e5\u786e\u5b9e\u65e0\u4e8b\u53ef\u505a\uff0c\u518d\u663e\u5f0f\u8c03\u7528 sleep \u5de5\u5177\u3002")})
            _timeline("autocontinue", n=STATE._autocontinue,
                      reason="\u89c4\u5212\u672a\u843d\u5730\u4e3a\u5de5\u5177\u8c03\u7528\uff0c\u81ea\u52a8\u50ac\u4fc3\u6267\u884c")
            if STATE.running:
                STATE.status = "active"
            return
        # No action proposed -> sleep to conserve credits. When the box is idle
        # (no training running) there is nothing to monitor, so sleep long
        # instead of waking every default_sleep_min; a user message / manual
        # wake / critical event brings it back instantly.
        try:
            import server
            n_train = int(server.processes().get("total", 0) or 0)
        except Exception:  # noqa: BLE001
            n_train = 0
        idle = n_train == 0
        mins = int(cfg.get("max_sleep_min", 240) if idle
                   else cfg["default_sleep_min"])
        STATE.status = "sleeping"
        STATE.sleep_until = time.time() + mins * 60
        STATE.sleep_reason = ("空闲无训练,长睡省额度" if idle
                              else "模型未提动作,默认休眠")
        STATE.wake_event.clear()
        _timeline("sleep", minutes=mins,
                  reason="auto idle (no training)" if idle else "auto (no tool call)")
        return

    STATE._autocontinue = 0  # model acted -> reset stall counter
    gated = set(cfg.get("gated_tools", []))
    n = len(tool_calls)
    i = 0
    while i < n:
        # Abort-signal check (claude-code pattern): a new user message or a stop
        # aborts the rest of the plan. Discarded calls still get a tool result
        # so the assistant turn stays valid for the next (re-planning) LLM call.
        if _should_abort():
            _fill_tool_results(tool_calls[i:],
                "INTERRUPTED:用户发来新消息或已停止,该工具调用被中止,即将重新规划。")
            _timeline("interrupted", phase="tools", dropped=n - i,
                      reason="用户消息" if STATE.user_inbox else "停止")
            if STATE.running:
                STATE.status = "active"
            return

        name, args, tcid = _parse_tc(tool_calls[i])

        # FORCED BEHAVIOR 1: must kb_query before any high-leverage action.
        if name in _REQUIRE_KB_FIRST and not _kb_query_in_recent(STATE.messages):
            STATE.messages.append({"role": "tool", "tool_call_id": tcid,
                "content": f"BLOCKED:执行 {name} 前必须先 kb_query 查既往坑/结论(行为规范,代码强制)。"
                           "请先调用 kb_query(关于本项目/本动作的关键词),再重试该动作。"})
            _fill_tool_results(tool_calls[i + 1:],
                "SKIPPED:前序动作被 kb_query 前置规则拦截,本调用未执行。")
            _timeline("kb_gate", tool=name,
                      reason="决策前未 kb_query,已拦截并要求先查知识库")
            if STATE.running:
                STATE.status = "active"
            return

        # FORCED BEHAVIOR 2: after a run ended, must record_gen before sleeping.
        if name == "sleep" and STATE.needs_summary and not STATE._recorded_since_wake:
            STATE.messages.append({"role": "tool", "tool_call_id": tcid,
                "content": "BLOCKED:刚有 run 结束,休眠前必须先 record_gen 记一笔台账"
                           "(并按需 kb_write 沉淀结论),再 sleep。"})
            _fill_tool_results(tool_calls[i + 1:],
                "SKIPPED:run 结束总结未完成,后续调用未执行。")
            _timeline("summary_gate", reason="run 结束未 record_gen,拦截 sleep")
            if STATE.running:
                STATE.status = "active"
            return

        # TIER-C gate: high-risk ops queue for human approval EVEN IN AUTO mode;
        # request mode additionally queues any tool in gated_tools.
        need_appr, appr_reason = _needs_approval(name, args, cfg)
        request_gated = cfg.get("mode") == "request" and name in gated
        if need_appr or request_gated:
            why = appr_reason or "请求模式:该动作需人工批准。"
            pend = {"id": f"act-{int(time.time()*1000)}-{len(STATE.pending)}",
                    "tool": name, "args": args, "reason": args.get("reason", ""),
                    "tool_call_id": tcid, "proposed_at": time.time(),
                    "risk": "high" if need_appr else "gated",
                    "approval_reason": why, "project": STATE.focus_project}
            STATE.pending.append(pend)
            STATE.messages.append({"role": "tool", "tool_call_id": tcid,
                                   "content": f"QUEUED[{'高风险' if need_appr else '请求模式'}]:"
                                              f"{why} 已生成待批卡,你已暂停。"})
            # any remaining calls this turn can't run until approval -> close them
            _fill_tool_results(tool_calls[i + 1:],
                "SKIPPED:前序动作待人工批准,本调用未执行。")
            _timeline("request", tool=name, args=args, reason=args.get("reason", ""),
                      action_id=pend["id"], risk=pend["risk"], approval_reason=why,
                      project=pend.get("project"))
            STATE.status = "waiting_approval"
            return  # stop stepping until approval

        # HARD safety rail (every mode, incl. full-auto): refuse irreversible /
        # runaway-burn ops outright. Unlike approval, this does NOT queue for a
        # human — the agent must scale the change down and retry, so the user
        # stays hands-free. (Concurrency/disk/GPU rails fire later in _guard_launch.)
        hard_reason = _hard_cap_violation(name, args, cfg)
        if hard_reason:
            STATE.messages.append({"role": "tool", "tool_call_id": tcid,
                "content": f"REFUSED[硬安全栏]:{hard_reason} 被硬上限拦下(防不可逆/烧钱失控),"
                           f"未执行。请改小幅度/参数后重试,不必等人工。"})
            _timeline("hard_cap_refused", tool=name, args=args, reason=hard_reason)
            i += 1
            continue

        # Batch a run of consecutive concurrency-safe reads -> execute parallel.
        if name in CONCURRENCY_SAFE_TOOLS:
            j = i
            batch: list[tuple[str, dict[str, Any], str]] = []
            while j < n:
                nm, ar, tid = _parse_tc(tool_calls[j])
                if nm not in CONCURRENCY_SAFE_TOOLS:
                    break
                batch.append((nm, ar, tid))
                j += 1
            results = _run_reads_parallel(batch, cfg)
            for (nm, ar, tid), res in zip(batch, results):
                STATE.messages.append({"role": "tool", "tool_call_id": tid,
                                       "content": json.dumps(res, ensure_ascii=False)})
            if len(batch) > 1:
                _timeline("parallel_reads", tools=[b[0] for b in batch])
            i = j
            continue

        # Serial single tool (write / control / deliberation).
        if name not in READ_TOOLS:
            _timeline("decision", tool=name, args=args, reason=args.get("reason", ""),
                      mode=cfg.get("mode"))
        result = _execute_tool(name, args, cfg)
        STATE.messages.append({"role": "tool", "tool_call_id": tcid,
                               "content": json.dumps(result, ensure_ascii=False)})
        if name not in READ_TOOLS:
            _timeline("executed", tool=name, result=result)
        if name == "sleep":
            return  # sleep already set status
        i += 1

    # If we executed actions (not sleep), loop again next iteration immediately.
    if STATE.status not in ("sleeping", "waiting_approval"):
        STATE.status = "active"


def _critical_wake(cfg: dict[str, Any]) -> Optional[str]:
    """Cheap, no-LLM check for events that should wake a sleeping agent."""
    import server
    reason = None
    try:
        st = server.system_status()
        disk = st.get("disk") or {}
        if disk.get("free_gb") is not None and disk["free_gb"] < cfg["disk_low_gb"]:
            return f"磁盘告警:剩 {disk['free_gb']}G"
        procs = server.processes()
        base = STATE._watch_baseline
        cur_total = procs.get("total", 0)
        cur_dp = procs.get("dp_count", 0)
        cur_pe = procs.get("pe_count", 0)
        if "proc_total" in base and cur_total < base["proc_total"]:
            # a run ended -> which project's count dropped? pre-set focus there
            # so the woken agent acts on the right project, and require a summary.
            dropped = None
            if cur_dp < base.get("dp", cur_dp):
                dropped = "dp"
            elif cur_pe < base.get("pe", cur_pe):
                dropped = "pe"
            if dropped:
                STATE.focus_project = dropped
                STATE.active_packs = set()
            STATE.needs_summary = True
            reason = (f"训练进程减少({base['proc_total']}→{cur_total}),"
                      f"{('['+dropped+'] ' ) if dropped else ''}run 结束—先总结再决策")
            try:
                reason += _watcher_campaign_selfheal(cfg)
            except Exception:  # noqa: BLE001
                pass
        base["proc_total"] = cur_total
        base["dp"] = cur_dp
        base["pe"] = cur_pe
        # extinction / error scan on the freshest PE log
        for p in sorted(server.PE_PANEL_LOGS.glob("onepot_sD_*.log"),
                        key=lambda x: x.stat().st_mtime, reverse=True)[:3]:
            try:
                tail = p.read_text(encoding="utf-8", errors="ignore").splitlines()[-60:]
            except Exception:  # noqa: BLE001
                continue
            if any("extinct" in ln.lower() for ln in tail):
                STATE.focus_project = "pe"      # extinction is always PE
                STATE.active_packs = set()
                return f"检测到灭绝事件(PE):{p.name}"
            # --- mid-training wake: check if current gen hits a wake point ---
            if STATE.wake_at_gens:
                for ln in reversed(tail):
                    if "Gen " in ln or "gen " in ln:
                        import re as _re
                        m = _re.search(r'[Gg]en\s+(\d+)', ln)
                        if m:
                            cur_gen = int(m.group(1))
                            for wg in STATE.wake_at_gens:
                                if cur_gen >= wg and wg not in STATE._wake_gens_triggered:
                                    STATE._wake_gens_triggered.add(wg)
                                    STATE.focus_project = "pe"
                                    return f"中间唤醒:PE 训练已到 gen {cur_gen}(检查点 gen>={wg})"
                        break
    except Exception:  # noqa: BLE001
        pass
    return reason


def _runner() -> None:
    while STATE.running:
        cfg = _load_config()
        st = STATE.status
        if st == "waiting_approval":
            time.sleep(0.5)
            continue
        if st == "sleeping":
            # auto-disk-protection even while asleep
            crit = _critical_wake(cfg)
            now = time.time()
            if crit or now >= STATE.sleep_until or STATE.wake_event.is_set() or STATE.user_inbox:
                STATE.stats["wakes"] += 1
                why = crit or ("用户消息" if STATE.user_inbox else
                               ("手动唤醒" if STATE.wake_event.is_set() else "到点"))
                STATE.wake_event.clear()
                # disk emergency: auto-cleanup before handing back to the model
                if crit and "磁盘" in crit:
                    # system-initiated cleanup; ensure a focus so the shared-tool
                    # guard passes (defaults to pe, where the big traces live).
                    if STATE.focus_project is None:
                        STATE.focus_project = "pe"
                    res = _execute_tool("cleanup_disk", {"project": STATE.focus_project,
                                        "reason": "磁盘告警自动清理"}, cfg)
                    _timeline("auto_cleanup", trigger=crit, result=res)
                _timeline("wake", reason=why,
                          focus=STATE.focus_project, needs_summary=STATE.needs_summary)
                focus_hint = (f" 本轮焦点已预设为 [{STATE.focus_project}]。"
                              if STATE.focus_project else
                              " 请先 focus_project(dp|pe) 设定本轮焦点。")
                summ_hint = (" 有 run 刚结束:先 kb_query 回顾→record_gen 记台账→"
                             "kb_write 沉淀结论,再决定下一步。"
                             if STATE.needs_summary else "")
                STATE.messages.append({"role": "user",
                                       "content": f"[唤醒] 原因: {why}。{focus_hint}{summ_hint}"})
                STATE.status = "active"
                STATE._recorded_since_wake = False
                STATE._deliberated_this_wake = False
                STATE._last_deliberation = []
                STATE._autocontinue = 0
                with STATE.lock:
                    STATE.live["deliberation"] = []
            else:
                time.sleep(min(cfg["poll_interval_s"], 5))
            continue
        if st in ("active", "error"):
            try:
                _do_step(cfg)
            except Exception as e:  # noqa: BLE001
                STATE.last_error = f"step crash: {e}"
                _timeline("error", text=STATE.last_error)
                STATE.status = "sleeping"
                STATE.sleep_until = time.time() + 60
            time.sleep(1.0)
            continue
        time.sleep(0.5)


def _ensure_thread() -> None:
    if STATE.thread and STATE.thread.is_alive():
        return
    STATE.thread = threading.Thread(target=_runner, daemon=True)
    STATE.thread.start()


# --------------------------------------------------------------------------- #
# Request models + routes.
# --------------------------------------------------------------------------- #
class ProviderReq(BaseModel):
    id: Optional[str] = None
    name: str
    base_url: str
    api_key: str
    model: str


class ActivateReq(BaseModel):
    id: str


class ModeReq(BaseModel):
    mode: str


class ConfigReq(BaseModel):
    max_procs: Optional[int] = None
    disk_low_gb: Optional[float] = None
    default_sleep_min: Optional[int] = None
    objective: Optional[str] = None
    gated_tools: Optional[list[str]] = None
    deep_think_rounds: Optional[int] = None
    active_strategy: Optional[str] = None
    tier_c: Optional[dict[str, Any]] = None


class StartReq(BaseModel):
    objective: Optional[str] = None


class MessageReq(BaseModel):
    text: str


class ApprovalReq(BaseModel):
    id: str
    reason: Optional[str] = ""


class FocusReq(BaseModel):
    project: str            # "dp" | "pe"
    reason: Optional[str] = ""


class RoadmapReq(BaseModel):
    # Board <-> agent shared plan. Any field omitted is left unchanged. When
    # `goals` is given it is a FULL ordered list (array order = attack order);
    # runtime state (status/progress/baseline) is preserved per-id on merge.
    objective: Optional[str] = None
    goals: Optional[list] = None
    hold_window: Optional[int] = None
    stall_after: Optional[int] = None
    stall_policy: Optional[str] = None
    active: Optional[bool] = None
    reason: Optional[str] = ""


def register_agent(app: Any) -> None:
    # Restore chat + dialogue context from the on-disk timeline so reopening the
    # page after a service restart looks exactly like before.
    _rehydrate()

    @app.get("/api/agent/state")
    def agent_state() -> dict[str, Any]:
        cfg = _load_config()
        return STATE.snapshot(cfg)

    @app.get("/api/agent/timeline")
    def agent_timeline(limit: int = 120) -> dict[str, Any]:
        return {"events": list(_TIMELINE_RING)[-limit:]}

    @app.get("/api/agent/models")
    def agent_models() -> dict[str, Any]:
        cfg = _load_config()
        return {"providers": _redact_providers(cfg),
                "active_provider": cfg.get("active_provider")}

    @app.post("/api/agent/models")
    def agent_add_model(req: ProviderReq) -> dict[str, Any]:
        cfg = _load_config()
        pid = req.id or re.sub(r"[^a-zA-Z0-9]+", "-", req.name.lower()).strip("-") or \
            f"m{int(time.time())}"
        prov = {"id": pid, "name": req.name, "base_url": req.base_url,
                "api_key": req.api_key, "model": req.model}
        provs = [p for p in cfg.get("providers", []) if p.get("id") != pid]
        provs.append(prov)
        cfg["providers"] = provs
        if not cfg.get("active_provider"):
            cfg["active_provider"] = pid
        _save_config(cfg)
        _timeline("model_added", id=pid, name=req.name, model=req.model)
        return {"ok": True, "id": pid, "providers": _redact_providers(cfg)}

    @app.delete("/api/agent/models/{pid}")
    def agent_del_model(pid: str) -> dict[str, Any]:
        cfg = _load_config()
        cfg["providers"] = [p for p in cfg.get("providers", []) if p.get("id") != pid]
        if cfg.get("active_provider") == pid:
            cfg["active_provider"] = (cfg["providers"][0]["id"]
                                      if cfg["providers"] else None)
        _save_config(cfg)
        return {"ok": True, "providers": _redact_providers(cfg)}

    @app.post("/api/agent/models/activate")
    def agent_activate_model(req: ActivateReq) -> dict[str, Any]:
        cfg = _load_config()
        if not any(p.get("id") == req.id for p in cfg.get("providers", [])):
            raise HTTPException(404, "provider not found")
        cfg["active_provider"] = req.id
        _save_config(cfg)
        return {"ok": True, "active_provider": req.id}

    @app.post("/api/agent/models/test")
    def agent_test_model(req: ActivateReq) -> dict[str, Any]:
        cfg = _load_config()
        # temporarily target the requested provider
        save = cfg.get("active_provider")
        cfg["active_provider"] = req.id
        try:
            msg = _chat(cfg, [{"role": "user", "content": "ping(只回 pong)"}])
            return {"ok": True, "reply": (msg.get("content") or "")[:200]}
        except urllib.error.HTTPError as e:
            return {"ok": False, "error": f"HTTP {e.code}: "
                    + e.read().decode('utf-8', 'ignore')[:300]}
        except Exception as e:  # noqa: BLE001
            return {"ok": False, "error": str(e)}
        finally:
            cfg["active_provider"] = save

    @app.post("/api/agent/mode")
    def agent_set_mode(req: ModeReq) -> dict[str, Any]:
        if req.mode not in ("request", "auto"):
            raise HTTPException(400, "mode must be 'request' or 'auto'")
        cfg = _load_config()
        cfg["mode"] = req.mode
        _save_config(cfg)
        _timeline("mode", mode=req.mode)
        return {"ok": True, "mode": req.mode}

    @app.post("/api/agent/focus")
    def agent_set_focus(req: FocusReq) -> dict[str, Any]:
        """Manually set the project focus from the UI (one decision = one
        project). Switching clears any activated long-tail tool packs."""
        if req.project not in ("dp", "pe"):
            raise HTTPException(400, "project must be 'dp' or 'pe'")
        with STATE.lock:
            STATE.focus_project = req.project
            STATE.active_packs = set()
        _timeline("focus_project", project=req.project,
                  reason=req.reason or "(UI 手动切换)")
        return {"ok": True, "focus_project": req.project, "active_packs": []}

    @app.get("/api/agent/roadmap")
    def agent_roadmap(refresh: int = 0) -> dict[str, Any]:
        # Pure read by default (cheap, board polls often). refresh=1 re-verifies
        # against live metrics — used sparingly (e.g. manual "刷新" button).
        if refresh:
            try:
                _roadmap_tick(_load_config())
            except Exception:  # noqa: BLE001
                pass
        return {"ok": True, **_roadmap_summary(_load_roadmap())}

    @app.post("/api/agent/roadmap")
    def agent_set_roadmap(req: RoadmapReq) -> dict[str, Any]:
        """Board edits the shared plan (add/edit/remove/reorder via full goals
        list, tweak objective/window/policy/active). Runtime state is preserved
        per-card; the agent reads this same file on its next heartbeat."""
        rm = _load_roadmap()
        if req.objective is not None:
            rm["objective"] = req.objective.strip()
        if req.hold_window is not None:
            rm["hold_window"] = max(1, int(req.hold_window))
        if req.stall_after is not None:
            rm["stall_after"] = max(1, int(req.stall_after))
        if req.stall_policy in ("skip", "hold"):
            rm["stall_policy"] = req.stall_policy
        if req.goals is not None:
            ok, err = _roadmap_merge_goals(rm, req.goals, owner="user")
            if not ok:
                raise HTTPException(400, err)
            rm["all_met_streak"] = 0
        if req.active is not None:
            rm["active"] = bool(req.active)
        elif req.goals is not None and rm.get("goals"):
            rm["active"] = True
        _save_roadmap(rm)
        _timeline("roadmap_user_edit", objective=rm.get("objective", ""),
                  goals=len(rm.get("goals", [])), reason=req.reason or "(网页编辑)")
        return {"ok": True, **_roadmap_summary(_load_roadmap())}

    @app.post("/api/agent/config")
    def agent_set_config(req: ConfigReq) -> dict[str, Any]:
        cfg = _load_config()
        for k in ("max_procs", "disk_low_gb", "default_sleep_min", "objective",
                  "gated_tools", "deep_think_rounds"):
            v = getattr(req, k)
            if v is not None:
                cfg[k] = v
        if req.active_strategy is not None:
            sid = req.active_strategy or None
            if sid and sid not in STRATEGIES:
                raise HTTPException(400, f"unknown strategy: {sid}")
            cfg["active_strategy"] = sid
        if req.tier_c is not None:
            tc = dict(cfg.get("tier_c") or {})
            tc.update({k: v for k, v in req.tier_c.items() if v is not None})
            cfg["tier_c"] = tc
        _save_config(cfg)
        return {"ok": True, "config": {k: cfg[k] for k in
                ("max_procs", "disk_low_gb", "default_sleep_min", "objective",
                 "gated_tools", "deep_think_rounds", "active_strategy", "tier_c")}}

    @app.post("/api/agent/start")
    def agent_start(req: StartReq) -> dict[str, Any]:
        cfg = _load_config()
        if not _active_provider(cfg):
            raise HTTPException(400, "请先注册并激活一个模型")
        if req.objective:
            cfg["objective"] = req.objective
            _save_config(cfg)
        with STATE.lock:
            if not STATE.messages:
                STATE.messages.append({"role": "user", "content":
                    f"开始值守。目标:{cfg.get('objective','')}。"
                    f"先 get_status 看现状,再决定要不要开训或休眠。"})
            STATE.running = True
            STATE.status = "active"
            STATE.last_error = ""
            STATE._deliberated_this_wake = False
            STATE._last_deliberation = []
            with STATE.lock:
                STATE.live["deliberation"] = []
        _ensure_thread()
        _timeline("agent_start", objective=cfg.get("objective"))
        return {"ok": True, "status": STATE.status}

    @app.post("/api/agent/stop")
    def agent_stop() -> dict[str, Any]:
        STATE.running = False
        STATE.status = "stopped"
        _timeline("agent_stop")
        return {"ok": True}

    @app.post("/api/agent/wake")
    def agent_wake() -> dict[str, Any]:
        STATE.wake_event.set()
        return {"ok": True}

    @app.post("/api/agent/message")
    def agent_message(req: MessageReq) -> dict[str, Any]:
        STATE.user_inbox.append(req.text)
        STATE.wake_event.set()
        _timeline("user_msg_queued", text=req.text)
        # if agent never started, start it so the user can chat immediately
        cfg = _load_config()
        if not STATE.running and _active_provider(cfg):
            STATE.running = True
            STATE.status = "active"
            _ensure_thread()
        return {"ok": True}

    @app.post("/api/agent/approve")
    def agent_approve(req: ApprovalReq) -> dict[str, Any]:
        cfg = _load_config()
        pend = next((p for p in STATE.pending if p["id"] == req.id), None)
        if not pend:
            raise HTTPException(404, "no such pending action")
        STATE.pending = [p for p in STATE.pending if p["id"] != req.id]
        # restore the focus that was active when this action was queued so the
        # project-partition guard inside _execute_tool lets it through.
        if pend.get("project") in ("dp", "pe"):
            STATE.focus_project = pend["project"]
        _timeline("decision", tool=pend["tool"], args=pend["args"],
                  reason=pend.get("reason", ""), approved=True)
        result = _execute_tool(pend["tool"], pend["args"], cfg)
        _timeline("executed", tool=pend["tool"], result=result, approved=True)
        STATE.messages.append({"role": "user", "content":
            f"[人工已批准 {pend['tool']}] 执行结果: "
            + json.dumps(result, ensure_ascii=False)})
        STATE.status = "active"
        return {"ok": True, "result": result}

    @app.post("/api/agent/reject")
    def agent_reject(req: ApprovalReq) -> dict[str, Any]:
        pend = next((p for p in STATE.pending if p["id"] == req.id), None)
        if not pend:
            raise HTTPException(404, "no such pending action")
        STATE.pending = [p for p in STATE.pending if p["id"] != req.id]
        _timeline("rejected", tool=pend["tool"], args=pend["args"],
                  reason=req.reason or "")
        STATE.messages.append({"role": "user", "content":
            f"[人工否决 {pend['tool']}] 理由: {req.reason or '(未填)'}。"
            f"请换个方案或休眠。"})
        STATE.status = "active"
        return {"ok": True}

    @app.post("/api/agent/clear_context")
    def agent_clear_context() -> dict[str, Any]:
        """Manually wipe the rolling dialogue context. The system prompt
        (role / red lines / strategy catalog / objective), pinned specs, the
        knowledge base and the gen ledger are ALL kept — only the chat history
        and rolling summary are dropped. The agent still knows the project."""
        cfg = _load_config()
        n = len(STATE.messages)
        with STATE.lock:
            STATE.messages = []
            STATE.user_inbox = []
            STATE.live["deliberation"] = []
        STATE._last_deliberation = []
        STATE._deliberated_this_wake = False
        if cfg.get("rolling_summary"):
            cfg["rolling_summary"] = ""
            _save_config(cfg)
        _timeline("context_cleared", dropped=n)
        return {"ok": True, "dropped": n}
