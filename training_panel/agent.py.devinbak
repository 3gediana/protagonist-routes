            {"file": {"type": "string", "description": "runs/dp_cf_<tag> 目录或其下 .jsonl 路径(可留空,自动取最新)"},
             "run_id": {"type": "string", "description": "或面板 run_id"}},
            []),
        _fn("inspect_config",
